<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <AssemblyName>Paddy</AssemblyName>
    <RootNamespace>Paddy</RootNamespace>
    <Version>0.6.1.0411</Version>
    <AssemblyVersion>0.6.1.0411</AssemblyVersion>
    <FileVersion>0.6.1.0411</FileVersion>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <ApplicationIcon>Paddy.ico</ApplicationIcon>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="NAudio" Version="2.3.0" />
    <PackageReference Include="NAudio.Lame" Version="2.1.0" />
    <PackageReference Include="NAudio.Vorbis" Version="1.5.0" />
    <PackageReference Include="Concentus" Version="2.2.2" />
    <PackageReference Include="Concentus.OggFile" Version="1.0.7" />
    <PackageReference Include="OggVorbisEncoder" Version="1.2.2" />
  </ItemGroup>
  <ItemGroup>
    <Resource Include="Paddy.ico" />
  </ItemGroup>
</Project>