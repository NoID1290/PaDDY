<UserControl x:Class="Paddy.Controls.RecordingPadButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="130" Height="90"
             Cursor="Hand">
    <UserControl.Resources>
        <!-- Playing animation: pulsing border -->
        <Storyboard x:Key="PlayingAnimation" RepeatBehavior="Forever">
            <ColorAnimation Storyboard.TargetName="TileBorder"
                            Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                            From="#FF4CAF50" To="#FF81C784"
                            Duration="0:0:0.6" AutoReverse="True"/>
        </Storyboard>
    </UserControl.Resources>

    <Border x:Name="TileBorder"
            Background="#FF2D2D2D"
            BorderBrush="#FF555555"
            BorderThickness="2"
            CornerRadius="8"
            SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="6" ShadowDepth="2" Opacity="0.4"/>
        </Border.Effect>

        <Border.Triggers>
            <EventTrigger RoutedEvent="MouseEnter">
                <BeginStoryboard>
                    <Storyboard>
                        <ColorAnimation Storyboard.TargetName="TileBorder"
                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                        To="#FF3A3A3A" Duration="0:0:0.1"/>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
            <EventTrigger RoutedEvent="MouseLeave">
                <BeginStoryboard>
                    <Storyboard>
                        <ColorAnimation Storyboard.TargetName="TileBorder"
                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                        To="#FF2D2D2D" Duration="0:0:0.1"/>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Border.Triggers>

        <Grid Margin="8,6">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Play/Stop icon -->
            <TextBlock x:Name="IconText"
                       Grid.Row="0"
                       Text="🎤"
                       FontSize="26"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>

            <!-- Recording name -->
            <TextBlock x:Name="NameLabel"
                       Grid.Row="1"
                       Text="Recording"
                       Foreground="#FFE0E0E0"
                       FontSize="10"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       TextTrimming="CharacterEllipsis"
                       MaxWidth="118"/>

            <!-- Duration -->
            <TextBlock x:Name="DurationLabel"
                       Grid.Row="2"
                       Text="0.0s"
                       Foreground="#FF9E9E9E"
                       FontSize="9"
                       HorizontalAlignment="Center"/>
        </Grid>
    </Border>

    <!-- Context menu -->
    <UserControl.ContextMenu>
        <ContextMenu>
            <MenuItem Header="▶  Play" Click="MenuPlay_Click"/>
            <MenuItem Header="⏹  Stop" Click="MenuStop_Click"/>
            <Separator/>
            <MenuItem Header="✏  Rename…" Click="MenuRename_Click"/>
            <MenuItem Header="📂  Open in Explorer" Click="MenuOpenExplorer_Click"/>
            <Separator/>
            <MenuItem Header="🗑  Delete" Click="MenuDelete_Click"/>
        </ContextMenu>
    </UserControl.ContextMenu>
</UserControl>
