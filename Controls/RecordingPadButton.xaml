<UserControl x:Class="PaDDY.Controls.RecordingPadButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="145"
        Height="90"
             Cursor="Hand"
             RenderTransformOrigin="0.5,0.5"
             MouseRightButtonDown="OnMouseRightButtonDown">
    <UserControl.RenderTransform>
        <ScaleTransform x:Name="CardScale" ScaleX="1" ScaleY="1"/>
    </UserControl.RenderTransform>
    <UserControl.Resources>
        <!-- Entrance animation: fade + slide up -->
        <Storyboard x:Key="EntranceAnimation">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="CardScale"
                             Storyboard.TargetProperty="ScaleX"
                             From="0.92" To="1" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="CardScale"
                             Storyboard.TargetProperty="ScaleY"
                             From="0.92" To="1" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- Small overlay-button style -->
        <Style x:Key="OverlayBtn"
                TargetType="Button">
            <Setter Property="Background"
                    Value="Transparent"/>
            <Setter Property="BorderThickness"
                    Value="0"/>
            <Setter Property="Padding"
                    Value="0"/>
            <Setter Property="Cursor"
                    Value="Hand"/>
            <Setter Property="FontSize"
                    Value="11"/>
            <Setter Property="Width"
                    Value="18"/>
            <Setter Property="Height"
                    Value="18"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center"
                                    VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                    Value="True">
                                <Setter TargetName="Bd"
                                        Property="Background"
                                        Value="#44FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border x:Name="TileBorder"
            Background="#FF2D2D2D"
            BorderBrush="#FF555555"
            BorderThickness="2"
            CornerRadius="8"
            SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect Color="Black"
                    BlurRadius="6"
                    ShadowDepth="2"
                    Opacity="0.4"/>
        </Border.Effect>

        <Border.Triggers>
            <EventTrigger RoutedEvent="MouseEnter">
                <BeginStoryboard>
                    <Storyboard>
                        <ColorAnimation Storyboard.TargetName="TileBorder"
                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                        To="#FF3A3A3A"
                                Duration="0:0:0.1"/>
                        <DoubleAnimation Storyboard.TargetName="CardScale"
                                         Storyboard.TargetProperty="ScaleX"
                                         To="1.04" Duration="0:0:0.15">
                            <DoubleAnimation.EasingFunction>
                                <CubicEase EasingMode="EaseOut"/>
                            </DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                        <DoubleAnimation Storyboard.TargetName="CardScale"
                                         Storyboard.TargetProperty="ScaleY"
                                         To="1.04" Duration="0:0:0.15">
                            <DoubleAnimation.EasingFunction>
                                <CubicEase EasingMode="EaseOut"/>
                            </DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
            <EventTrigger RoutedEvent="MouseLeave">
                <BeginStoryboard>
                    <Storyboard>
                        <ColorAnimation Storyboard.TargetName="TileBorder"
                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                        To="#FF2D2D2D"
                                Duration="0:0:0.1"/>
                        <DoubleAnimation Storyboard.TargetName="CardScale"
                                         Storyboard.TargetProperty="ScaleX"
                                         To="1.0" Duration="0:0:0.15">
                            <DoubleAnimation.EasingFunction>
                                <CubicEase EasingMode="EaseOut"/>
                            </DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                        <DoubleAnimation Storyboard.TargetName="CardScale"
                                         Storyboard.TargetProperty="ScaleY"
                                         To="1.0" Duration="0:0:0.15">
                            <DoubleAnimation.EasingFunction>
                                <CubicEase EasingMode="EaseOut"/>
                            </DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
            <EventTrigger RoutedEvent="PreviewMouseLeftButtonDown">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetName="CardScale"
                                         Storyboard.TargetProperty="ScaleX"
                                         To="0.96" Duration="0:0:0.08"/>
                        <DoubleAnimation Storyboard.TargetName="CardScale"
                                         Storyboard.TargetProperty="ScaleY"
                                         To="0.96" Duration="0:0:0.08"/>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
            <EventTrigger RoutedEvent="PreviewMouseLeftButtonUp">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetName="CardScale"
                                         Storyboard.TargetProperty="ScaleX"
                                         To="1.04" Duration="0:0:0.1">
                            <DoubleAnimation.EasingFunction>
                                <CubicEase EasingMode="EaseOut"/>
                            </DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                        <DoubleAnimation Storyboard.TargetName="CardScale"
                                         Storyboard.TargetProperty="ScaleY"
                                         To="1.04" Duration="0:0:0.1">
                            <DoubleAnimation.EasingFunction>
                                <CubicEase EasingMode="EaseOut"/>
                            </DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Border.Triggers>

        <!-- Root grid: content + overlay buttons -->
        <Grid>
            <!-- Main content -->
            <Grid Margin="8,6">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Play/Stop icon -->
                <TextBlock x:Name="IconText"
                           Grid.Row="0"
                           Text="🎤"
                           FontSize="26"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>

                <!-- Recording name -->
                <TextBlock x:Name="NameLabel"
                           Grid.Row="1"
                           Text="Recording"
                           Foreground="#FFE0E0E0"
                           FontSize="10"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           MaxWidth="125"/>

                <!-- Duration -->
                <TextBlock x:Name="DurationLabel"
                           Grid.Row="2"
                           Text="0.0s"
                           Foreground="#FF9E9E9E"
                           FontSize="9"
                           HorizontalAlignment="Center"/>
            </Grid>

            <!-- Overlay buttons -->
            <Grid>
                <!-- ⭐ Favourite — top-left -->
                <Button x:Name="FavBtn"
                        Style="{StaticResource OverlayBtn}"
                        Content="☆"
                        Foreground="#FFAAAAAA"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Margin="4,4,0,0"
                        ToolTip="Toggle favourite"
                        Click="FavBtn_Click"/>

                <!-- ✕ Delete — top-right -->
                <Button x:Name="DelBtn"
                        Content="✕"
                        Foreground="#FFAAAAAA"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,4,4,0"
                        ToolTip="Delete"
                        Click="DelBtn_Click">
                    <Button.Style>
                        <Style TargetType="Button"
                                BasedOn="{StaticResource OverlayBtn}">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver"
                                        Value="True">
                                    <Setter Property="Foreground"
                                            Value="#FFEF5350"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- ✏ Rename — bottom-right -->
                <Button x:Name="RenameBtn"
                        Style="{StaticResource OverlayBtn}"
                        Content="✏"
                        Foreground="#FFAAAAAA"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Margin="0,0,4,4"
                        ToolTip="Rename"
                        Click="RenameBtn_Click"/>

                <!-- ✂ Trim — bottom-left -->
                <Button x:Name="TrimBtn"
                        Style="{StaticResource OverlayBtn}"
                        Content="✂"
                        Foreground="#FFAAAAAA"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Bottom"
                        Margin="4,0,0,4"
                        ToolTip="Trim / Edit"
                        Click="TrimBtn_Click"/>
            </Grid>
        </Grid>
    </Border>
</UserControl>
