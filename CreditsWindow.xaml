<Window x:Class="PaDDY.CreditsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Credits and Licenses"
        Icon="PaDDY.ico"
        Width="780" Height="640"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource WindowGlowBrush}"
        Foreground="{StaticResource PrimaryTextBrush}"
        FontFamily="{DynamicResource AppFont}">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="36"
                      GlassFrameThickness="0"
                      ResizeBorderThickness="4"
                      UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Grid Margin="10">
        <Border Style="{StaticResource SecondaryWindowFrame}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="36"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Custom title bar -->
                <Border Grid.Row="0"
                        Background="{StaticResource TitleBarGradient}"
                        BorderBrush="#16FFFFFF"
                        BorderThickness="0,0,0,1"
                        CornerRadius="12,12,0,0">
                    <Grid>
                        <TextBlock Text="Credits and Licenses"
                                   Foreground="#FF8080A8"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   Margin="16,0,0,0"/>
                        <Button Style="{StaticResource ChromeCloseBtn}"
                                HorizontalAlignment="Right"
                                ToolTip="Close"
                                Click="ChromeClose_Click">
                            <TextBlock Text="&#x2715;" FontSize="11" FontFamily="Segoe UI"/>
                        </Button>
                    </Grid>
                </Border>

                <Grid Grid.Row="1" Margin="18">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Style="{StaticResource SecondaryWindowHeaderCard}"
                BorderBrush="#22FFFFFF"
                Padding="16,10"
                Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Pa" Foreground="#FF7070A8" FontSize="17" FontWeight="Bold"/>
                <TextBlock Text="DDY" Foreground="#FF4CAF50" FontSize="17" FontWeight="Bold"/>
                <TextBlock Text="  —  Third-Party Credits &amp; Licenses"
                           Foreground="#FF9090B8"
                           FontSize="13"
                           VerticalAlignment="Center"
                           Margin="4,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Credits text area -->
        <Border Grid.Row="1"
                Background="#FF0E1019"
                BorderBrush="#28FFFFFF"
                BorderThickness="1"
                CornerRadius="7">
            <Border.Effect>
                <StaticResource ResourceKey="PanelShadow"/>
            </Border.Effect>
            <TextBox x:Name="CreditsTextBox"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Disabled"
                     FontFamily="Consolas"
                     FontSize="12"
                     Background="Transparent"
                     Foreground="#FFB8B8D8"
                     BorderThickness="0"
                     Padding="12"
                     AcceptsReturn="True"
                     CaretBrush="#FF4CAF50"
                     SelectionBrush="#224CAF50"
                     Height="Auto"
                     VerticalAlignment="Stretch"
                     VerticalContentAlignment="Top"/>
        </Border>

        <!-- Footer -->
        <Border Grid.Row="2"
            Background="{StaticResource SecondaryFooterBackgroundBrush}"
                BorderBrush="#14FFFFFF"
                BorderThickness="0,1,0,0"
                Padding="0,12,0,0"
                Margin="0,10,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Open Licenses Folder"
                        Width="155"
                        Margin="0,0,8,0"
                        Click="OpenLicensesFolder_Click"/>
                <Button Content="Close"
                        Width="90"
                        IsDefault="True"
                        IsCancel="True"
                        Click="CloseButton_Click"/>
            </StackPanel>
        </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
