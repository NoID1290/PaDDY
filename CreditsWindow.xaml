<Window x:Class="PaDDY.CreditsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Credits and Licenses"
        Icon="PaDDY.ico"
        Width="780" Height="640"
        WindowStartupLocation="CenterOwner"
        Background="#FF0D0D14"
        Foreground="#FFE0E8F0"
        FontFamily="{DynamicResource AppFont}">

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="#FF181826"
                BorderBrush="#22FFFFFF"
                BorderThickness="1"
                CornerRadius="7"
                Padding="16,10"
                Margin="0,0,0,12">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="2" BlurRadius="10" Color="#FF000000" Opacity="0.45"/>
            </Border.Effect>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Pa" Foreground="#FF7070A8" FontSize="17" FontWeight="Bold"/>
                <TextBlock Text="DDY" Foreground="#FF4CAF50" FontSize="17" FontWeight="Bold"/>
                <TextBlock Text="  —  Third-Party Credits &amp; Licenses"
                           Foreground="#FF9090B8"
                           FontSize="13"
                           VerticalAlignment="Center"
                           Margin="4,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Credits text area -->
        <Border Grid.Row="1"
                Background="#FF0A0A14"
                BorderBrush="#28FFFFFF"
                BorderThickness="1"
                CornerRadius="7">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="2" BlurRadius="12" Color="#FF000000" Opacity="0.5"/>
            </Border.Effect>
            <TextBox x:Name="CreditsTextBox"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Disabled"
                     FontFamily="Consolas"
                     FontSize="12"
                     Background="Transparent"
                     Foreground="#FFB8B8D8"
                     BorderThickness="0"
                     Padding="12"
                     AcceptsReturn="True"
                     CaretBrush="#FF4CAF50"
                     SelectionBrush="#224CAF50"
                     Height="Auto"
                     VerticalAlignment="Stretch"
                     VerticalContentAlignment="Top"/>
        </Border>

        <!-- Footer -->
        <Border Grid.Row="2"
                Background="#FF141420"
                BorderBrush="#14FFFFFF"
                BorderThickness="0,1,0,0"
                Padding="0,12,0,0"
                Margin="0,10,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Open Licenses Folder"
                        Width="155"
                        Margin="0,0,8,0"
                        Click="OpenLicensesFolder_Click"/>
                <Button Content="Close"
                        Width="90"
                        IsDefault="True"
                        IsCancel="True"
                        Click="CloseButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
