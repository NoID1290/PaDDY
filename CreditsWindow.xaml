<Window x:Class="PaDDY.CreditsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Credits and Licenses"
        Icon="PaDDY.ico"
        Width="780"
        Height="640"
        WindowStartupLocation="CenterOwner"
        Background="#FF1E1E1E"
        Foreground="#FFE0E0E0"
        FontFamily="Segoe UI">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFD0D0D0"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#FF353535"/>
            <Setter Property="Foreground" Value="#FFE0E0E0"/>
            <Setter Property="BorderBrush" Value="#FF555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF454545"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="PaDDY Third-Party Credits and Licenses"
                   FontSize="20"
                   FontWeight="SemiBold"
                   Foreground="#FF4CAF50"
                   Margin="0,0,0,8"/>

        <TextBlock Grid.Row="1"
                   Text=""
                   FontSize="12"
                   Foreground="#FFB0B0B0"
                   Margin="0,0,0,10"/>

        <Border Grid.Row="2"
                Background="#FF252525"
                BorderBrush="#FF3A3A3A"
                BorderThickness="1"
                CornerRadius="4"
                Padding="8">
            <TextBox x:Name="CreditsTextBox"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Disabled"
                     FontFamily="Consolas"
                     FontSize="12"
                     Background="#FF1E1E1E"
                     Foreground="#FFE0E0E0"
                     BorderThickness="0"
                     AcceptsReturn="True"/>
        </Border>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">
            <Button Content="Open Licenses Folder"
                    Width="150"
                    Margin="0,0,8,0"
                    Click="OpenLicensesFolder_Click"/>
            <Button Content="Close"
                    Width="90"
                    IsDefault="True"
                    IsCancel="True"
                    Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
