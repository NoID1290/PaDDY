<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════════
         BRUSH / COLOR RESOURCES
    ═══════════════════════════════════════════════════════════════ -->
    <SolidColorBrush x:Key="WindowBgBrush"       Color="#FF0D0D14"/>
    <SolidColorBrush x:Key="CardBgBrush"         Color="#FF1A1A28"/>
    <SolidColorBrush x:Key="CardBorderBrush"     Color="#28FFFFFF"/>
    <SolidColorBrush x:Key="SubtleTextBrush"     Color="#FF7070A0"/>
    <SolidColorBrush x:Key="PrimaryTextBrush"    Color="#FFE8E8F4"/>
    <SolidColorBrush x:Key="SecondaryTextBrush"  Color="#FFB0B0CC"/>
    <SolidColorBrush x:Key="AccentGreenBrush"    Color="#FF4CAF50"/>
    <SolidColorBrush x:Key="AccentRedBrush"      Color="#FFC62828"/>
    <SolidColorBrush x:Key="AccentAmberBrush"    Color="#FFFFC107"/>
    <SolidColorBrush x:Key="InputBgBrush"        Color="#FF141420"/>
    <SolidColorBrush x:Key="InputBorderBrush"    Color="#2AFFFFFF"/>

    <!-- ═══════════════════════════════════════════════════════════════
         BASE CONTROL STYLES (implicit / no x:Key = apply to all)
    ═══════════════════════════════════════════════════════════════ -->

    <!-- TextBlock -->
    <Style TargetType="TextBlock">
        <Setter Property="Foreground"        Value="#FFD0D0E0"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- Label -->
    <Style TargetType="Label">
        <Setter Property="Foreground"        Value="#FFB0B0CC"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Padding"           Value="0"/>
    </Style>

    <!-- Slider  (minimal override – keeps system thumb chrome) -->
    <Style TargetType="Slider">
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Foreground"        Value="#FF4CAF50"/>
    </Style>

    <!-- CheckBox -->
    <Style TargetType="CheckBox">
        <Setter Property="Foreground"        Value="#FFD0D0E0"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- TextBox -->
    <Style TargetType="TextBox">
        <Setter Property="Background"              Value="#FF141420"/>
        <Setter Property="Foreground"              Value="#FFE8E8F4"/>
        <Setter Property="BorderBrush"             Value="#2AFFFFFF"/>
        <Setter Property="BorderThickness"         Value="1"/>
        <Setter Property="Height"                  Value="28"/>
        <Setter Property="Padding"                 Value="7,4"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="CaretBrush"              Value="White"/>
    </Style>

    <!-- Button -->
    <Style TargetType="Button">
        <Setter Property="Background"      Value="#FF1C1C2C"/>
        <Setter Property="Foreground"      Value="#FFD0D0E0"/>
        <Setter Property="BorderBrush"     Value="#2AFFFFFF"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding"         Value="12,5"/>
        <Setter Property="Height"          Value="30"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background"   Value="#FF282840"/>
                            <Setter TargetName="Bd" Property="BorderBrush"  Value="#44FFFFFF"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background"   Value="#FF0F0F1C"/>
                            <Setter TargetName="Bd" Property="BorderBrush"  Value="#18FFFFFF"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.38"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ComboBox (fully retemplated glass dark) -->
    <Style TargetType="ComboBox">
        <Setter Property="Background"               Value="#FF141420"/>
        <Setter Property="Foreground"               Value="#FFE8E8F4"/>
        <Setter Property="BorderBrush"              Value="#2AFFFFFF"/>
        <Setter Property="Height"                   Value="28"/>
        <Setter Property="Padding"                  Value="7,3"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="ItemContainerStyle">
            <Setter.Value>
                <Style TargetType="ComboBoxItem">
                    <Setter Property="Foreground"              Value="#FFE8E8F4"/>
                    <Setter Property="Background"              Value="#FF10101E"/>
                    <Setter Property="Padding"                 Value="9,6"/>
                    <Setter Property="HorizontalContentAlignment" Value="Left"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ComboBoxItem">
                                <Border x:Name="Bd"
                                        Background="{TemplateBinding Background}"
                                        BorderThickness="0"
                                        Padding="{TemplateBinding Padding}"
                                        SnapsToDevicePixels="True">
                                    <ContentPresenter
                                        HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                        VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                        SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsHighlighted" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#FF3E4A5A"/>
                                        <Setter Property="Foreground"                 Value="#FFFFFFFF"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#FF2A5A8E"/>
                                        <Setter Property="Foreground"                 Value="#FFFFFFFF"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Foreground" Value="#FF606070"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <ToggleButton x:Name="ToggleButton"
                                      Focusable="False"
                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay,
                                          RelativeSource={RelativeSource TemplatedParent}}"
                                      ClickMode="Press">
                            <ToggleButton.Style>
                                <Style TargetType="ToggleButton">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border x:Name="Bd"
                                                        Background="#FF141420"
                                                        BorderBrush="#2AFFFFFF"
                                                        BorderThickness="1"
                                                        CornerRadius="6">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition/>
                                                            <ColumnDefinition Width="22"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Path Grid.Column="1"
                                                              Width="10" Height="6"
                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"
                                                              Fill="#FF8090B0"
                                                              Data="M 0 0 L 10 0 L 5 6 Z"/>
                                                    </Grid>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter TargetName="Bd" Property="BorderBrush" Value="#604CAF50"/>
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background"  Value="#FF1C1C2C"/>
                                                        <Setter TargetName="Bd" Property="BorderBrush" Value="#44FFFFFF"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ToggleButton.Style>
                        </ToggleButton>

                        <ContentPresenter x:Name="ContentSite"
                                          Margin="8,0,26,0"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Left"
                                          IsHitTestVisible="False"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"/>

                        <Popup x:Name="PART_Popup"
                               Placement="Bottom"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               AllowsTransparency="True"
                               Focusable="False"
                               PopupAnimation="Slide">
                            <Border Background="#FF10101E"
                                    BorderBrush="#38FFFFFF"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    MinWidth="{TemplateBinding ActualWidth}"
                                    MaxHeight="300"
                                    SnapsToDevicePixels="True">
                                <Border.Effect>
                                    <DropShadowEffect ShadowDepth="4" BlurRadius="16"
                                                      Color="#FF000000" Opacity="0.7"/>
                                </Border.Effect>
                                <ScrollViewer SnapsToDevicePixels="True">
                                    <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         KEYED STYLES
    ═══════════════════════════════════════════════════════════════ -->

    <!-- GlassCard: main card surface with subtle glow border -->
    <Style x:Key="GlassCard" TargetType="Border">
        <Setter Property="Background"      Value="#FF181826"/>
        <Setter Property="BorderBrush"     Value="#28FFFFFF"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius"    Value="9"/>
        <Setter Property="Padding"         Value="14,10"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect ShadowDepth="2" BlurRadius="14"
                                  Color="#FF000000" Opacity="0.45"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- SectionTitle: uppercase glassmorphic card title -->
    <Style x:Key="SectionTitle" TargetType="TextBlock">
        <Setter Property="Foreground"   Value="#FF5A9070"/>
        <Setter Property="FontSize"     Value="10"/>
        <Setter Property="FontWeight"   Value="SemiBold"/>
        <Setter Property="Margin"       Value="0,0,0,8"/>
        <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
    </Style>

    <!-- ConfigLabel: label beside a control inside the config panel -->
    <Style x:Key="ConfigLabel" TargetType="TextBlock">
        <Setter Property="Foreground"        Value="#FF8080A8"/>
        <Setter Property="FontSize"          Value="10"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin"            Value="0,0,6,0"/>
    </Style>

    <!-- ValueBadge: small readout box next to sliders -->
    <Style x:Key="ValueBadge" TargetType="Border">
        <Setter Property="Background"      Value="#FF0C0C18"/>
        <Setter Property="BorderBrush"     Value="#28FFFFFF"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius"    Value="5"/>
        <Setter Property="Padding"         Value="5,1"/>
        <Setter Property="Margin"          Value="6,0,0,0"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- InfoLineLabel: compact info text in the status bar -->
    <Style x:Key="InfoLineLabel" TargetType="TextBlock">
        <Setter Property="Foreground"    Value="#FF606088"/>
        <Setter Property="FontSize"      Value="10"/>
        <Setter Property="Margin"        Value="0,2,0,0"/>
        <Setter Property="TextTrimming"  Value="CharacterEllipsis"/>
    </Style>

</ResourceDictionary>
