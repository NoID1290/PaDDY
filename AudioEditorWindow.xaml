<Window x:Class="PaDDY.AudioEditorWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Trim Audio"
        Icon="PaDDY.ico"
        Width="820" Height="420"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource WindowGlowBrush}"
        Foreground="{StaticResource PrimaryTextBrush}"
        FontFamily="{DynamicResource AppFont}">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="36"
                      GlassFrameThickness="0"
                      ResizeBorderThickness="0"
                      UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- Glass-style editor button (inherits AppTheme Button, just sets keyed override) -->
        <Style x:Key="EditorBtn" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Padding"   Value="16,7"/>
            <Setter Property="FontSize"  Value="12"/>
            <Setter Property="Height"    Value="34"/>
        </Style>

        <!-- Primary action (Save Trim) -->
        <Style x:Key="PrimaryBtn" TargetType="Button" BasedOn="{StaticResource EditorBtn}">
            <Setter Property="Background"  Value="#FF1A2E1A"/>
            <Setter Property="BorderBrush" Value="#404CAF50"/>
            <Setter Property="Foreground"  Value="#FFAAD4AA"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Border Style="{StaticResource SecondaryWindowFrame}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="36"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Custom title bar -->
                <Border Grid.Row="0"
                        Background="{StaticResource TitleBarGradient}"
                        BorderBrush="#16FFFFFF"
                        BorderThickness="0,0,0,1"
                        CornerRadius="12,12,0,0">
                    <Grid>
                        <TextBlock Text="Trim Audio"
                                   Foreground="#FF8080A8"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   Margin="16,0,0,0"/>
                        <Button Style="{StaticResource ChromeCloseBtn}"
                                HorizontalAlignment="Right"
                                ToolTip="Close"
                                Click="ChromeClose_Click">
                            <TextBlock Text="&#x2715;" FontSize="11" FontFamily="Segoe UI"/>
                        </Button>
                    </Grid>
                </Border>

                <Grid Grid.Row="1" Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

        <!-- Row 0 — Header -->
        <Border Grid.Row="0"
                Style="{StaticResource SecondaryWindowHeaderCard}"
                BorderBrush="#22FFFFFF"
                Padding="14,8"
                Margin="0,0,0,10">
            <DockPanel>
                <TextBlock x:Name="FileNameLabel"
                           Text="filename.wav"
                           Foreground="#FFD0D8F0"
                           FontSize="13"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="TotalDurationLabel"
                           Text="0.0s"
                           Foreground="#FF6060A0"
                           FontSize="11"
                           Margin="12,0,0,0"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Row 1 — Waveform area + vertical meter -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="60"/>
            </Grid.ColumnDefinitions>

            <!-- Waveform -->
            <Border Grid.Column="0"
                    Background="#FF0D1019"
                    BorderBrush="#28FFFFFF"
                    BorderThickness="1"
                    CornerRadius="7"
                    ClipToBounds="True">
                <Border.Effect>
                    <StaticResource ResourceKey="PanelShadow"/>
                </Border.Effect>
                <Grid x:Name="WaveformGrid">
                    <Image x:Name="WaveformImage"
                           Stretch="Fill"
                           RenderOptions.BitmapScalingMode="NearestNeighbor"/>

                    <Border x:Name="LeftOverlay"
                            Background="#88000010"
                            HorizontalAlignment="Left"
                            Width="0"/>
                    <Border x:Name="RightOverlay"
                            Background="#88000010"
                            HorizontalAlignment="Right"
                            Width="0"/>

                    <!-- Playback position indicator -->
                    <Border x:Name="PlaybackLine"
                            Background="#FFFFC107"
                            Width="2"
                            HorizontalAlignment="Left"
                            Margin="0"
                            Visibility="Collapsed">
                        <Border.RenderTransform>
                            <TranslateTransform x:Name="PlaybackLineTransform" X="0"/>
                        </Border.RenderTransform>
                    </Border>

                    <!-- Left trim handle -->
                    <Thumb x:Name="LeftHandle"
                           Width="10"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Stretch"
                           Cursor="SizeWE"
                           DragDelta="LeftHandle_DragDelta">
                        <Thumb.Template>
                            <ControlTemplate TargetType="Thumb">
                                <Border Background="#CC4CAF50"
                                        CornerRadius="4,0,0,4"
                                        BorderBrush="#FF66BB6A"
                                        BorderThickness="2,0,0,0"/>
                            </ControlTemplate>
                        </Thumb.Template>
                    </Thumb>

                    <!-- Right trim handle -->
                    <Thumb x:Name="RightHandle"
                           Width="10"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Stretch"
                           Cursor="SizeWE"
                           DragDelta="RightHandle_DragDelta">
                        <Thumb.Template>
                            <ControlTemplate TargetType="Thumb">
                                <Border Background="#CC4CAF50"
                                        CornerRadius="0,4,4,0"
                                        BorderBrush="#FF66BB6A"
                                        BorderThickness="0,0,2,0"/>
                            </ControlTemplate>
                        </Thumb.Template>
                    </Thumb>
                </Grid>
            </Border>

            <!-- Vertical level meter -->
            <Border Grid.Column="1"
                    Background="#FF0D1019"
                    BorderBrush="#28FFFFFF"
                    BorderThickness="1"
                    CornerRadius="7"
                    Margin="6,0,0,0"
                    ClipToBounds="True">
                <Border.Effect>
                    <StaticResource ResourceKey="PanelShadow"/>
                </Border.Effect>
                <Grid x:Name="VertMeterHost" Margin="1"/>
            </Border>
        </Grid>

        <!-- Row 2 — Time labels -->
        <Grid Grid.Row="2" Margin="2,7,2,0">
            <TextBlock x:Name="StartTimeLabel"
                       Text="0.00s"
                       Foreground="#FF4CAF50"
                       FontSize="11"
                       HorizontalAlignment="Left"/>
            <TextBlock x:Name="TrimmedDurationLabel"
                       Text="Trimmed: 0.0s"
                       Foreground="#FF606090"
                       FontSize="11"
                       HorizontalAlignment="Center"/>
            <TextBlock x:Name="EndTimeLabel"
                       Text="0.00s"
                       Foreground="#FF4CAF50"
                       FontSize="11"
                       HorizontalAlignment="Right"/>
        </Grid>

        <!-- Row 3 — Gain control -->
        <Border Grid.Row="3"
            Style="{StaticResource SecondaryWindowHeaderCard}"
                BorderBrush="#18FFFFFF"
                Padding="12,7"
                Margin="0,8,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="44"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="56"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="Gain"
                           Foreground="#FF8080A8"
                           VerticalAlignment="Center"
                           FontSize="11"/>
                <Slider x:Name="GainSlider"
                        Grid.Column="1"
                        Minimum="-24"
                        Maximum="24"
                        Value="0"
                        TickFrequency="1"
                        IsSnapToTickEnabled="True"
                        VerticalAlignment="Center"
                        ValueChanged="GainSlider_ValueChanged"/>
                <TextBlock x:Name="GainLabel"
                           Grid.Column="2"
                           Text="0 dB"
                           Foreground="#FF6060A0"
                           FontSize="11"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Row 4 — Action buttons -->
        <Border Grid.Row="4"
            Background="{StaticResource SecondaryFooterBackgroundBrush}"
                BorderBrush="#14FFFFFF"
                BorderThickness="0,1,0,0"
                Padding="0,12,0,0"
                Margin="0,10,0,0">
            <DockPanel LastChildFill="False">
                <!-- Left: Preview + Add to Favourites -->
                <Button x:Name="PlayBtn"
                        Style="{StaticResource EditorBtn}"
                        Content="▶  Preview"
                        DockPanel.Dock="Left"
                        Click="PlayBtn_Click"/>
                <CheckBox x:Name="SaveToFavCheckBox"
                          Content="Add to Favourites"
                          Foreground="#FFB0B0CC"
                          DockPanel.Dock="Left"
                          Margin="14,0,0,0"
                          VerticalAlignment="Center"/>

                <!-- Right: Cancel, Save as Copy, Save Trim -->
                <Button x:Name="SaveBtn"
                        Style="{StaticResource PrimaryBtn}"
                        Content="✂  Save Trim"
                        DockPanel.Dock="Right"
                        Margin="8,0,0,0"
                        Click="SaveBtn_Click"/>
                <Button x:Name="SaveCopyBtn"
                        Style="{StaticResource EditorBtn}"
                        Content="✂  Save as Copy"
                        DockPanel.Dock="Right"
                        Margin="8,0,0,0"
                        Click="SaveCopyBtn_Click"/>
                <Button Style="{StaticResource EditorBtn}"
                        Content="Cancel"
                        DockPanel.Dock="Right"
                        IsCancel="True"/>
            </DockPanel>
        </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
