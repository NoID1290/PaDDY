<Window x:Class="PaDDY.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PaDDY — Settings"
        Icon="PaDDY.ico"
        Width="520"
        Height="640"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#FF0D0D14"
        Foreground="#FFE0E8F0"
        FontFamily="{DynamicResource AppFont}">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="36"
                      GlassFrameThickness="0"
                      ResizeBorderThickness="0"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>

        <!-- Section header with left accent bar -->
        <Style x:Key="GroupHeader" TargetType="StackPanel">
            <Setter Property="Orientation" Value="Horizontal"/>
            <Setter Property="Margin"      Value="0,0,0,8"/>
        </Style>

        <!-- Accent bar used in group headers -->
        <Style x:Key="HeaderAccentBar" TargetType="Rectangle">
            <Setter Property="Width"        Value="3"/>
            <Setter Property="Height"       Value="11"/>
            <Setter Property="Fill"         Value="#FF4CAF50"/>
            <Setter Property="RadiusX"      Value="1"/>
            <Setter Property="RadiusY"      Value="1"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin"       Value="0,0,7,0"/>
        </Style>

        <!-- Header text -->
        <Style x:Key="HeaderText" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="#FF5A9070"/>
            <Setter Property="FontSize"    Value="10"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Settings row label -->
        <Style x:Key="SettingsLabel" TargetType="TextBlock">
            <Setter Property="Foreground"        Value="#FF9090B8"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize"          Value="11"/>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Custom title bar -->
        <Border Grid.Row="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#FF141422" Offset="0"/>
                    <GradientStop Color="#FF0F0F1A" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <TextBlock Text="PaDDY — Settings"
                           Foreground="#FF8080A8"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Margin="16,0,0,0"/>
                <Button Style="{StaticResource ChromeCloseBtn}"
                        HorizontalAlignment="Right"
                        ToolTip="Close"
                        Click="ChromeClose_Click">
                    <TextBlock Text="&#x2715;" FontSize="11" FontFamily="Segoe UI"/>
                </Button>
            </Grid>
        </Border>

        <!-- Existing content -->
        <Grid Grid.Row="1" Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- ── Recording Format ── -->
                <StackPanel Style="{StaticResource GroupHeader}">
                    <Rectangle Style="{StaticResource HeaderAccentBar}"/>
                    <TextBlock Text="RECORDING FORMAT" Style="{StaticResource HeaderText}"/>
                </StackPanel>
                <Border Style="{StaticResource GlassCard}" Margin="0,0,0,16">
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Codec:"
                                       Style="{StaticResource SettingsLabel}"/>
                            <ComboBox x:Name="CodecCombo"
                                      Grid.Column="1"
                                      SelectionChanged="CodecCombo_SelectionChanged"/>
                        </Grid>
                        <TextBlock x:Name="CodecInfoText"
                                   TextWrapping="Wrap"
                                   Foreground="#FF606090"
                                   FontSize="11"/>
                    </StackPanel>
                </Border>

                <!-- ── Save Folder ── -->
                <StackPanel Style="{StaticResource GroupHeader}">
                    <Rectangle Style="{StaticResource HeaderAccentBar}"/>
                    <TextBlock Text="SAVE FOLDER" Style="{StaticResource HeaderText}"/>
                </StackPanel>
                <Border Style="{StaticResource GlassCard}" Margin="0,0,0,16">
                    <DockPanel>
                        <Button DockPanel.Dock="Right"
                                Content="&#x1F4C1; Browse…"
                                Padding="12,5"
                                Margin="10,0,0,0"
                                Click="BrowseFolder_Click"/>
                        <TextBox x:Name="SaveFolderBox"
                                 IsReadOnly="True"/>
                    </DockPanel>
                </Border>

                <!-- ── Buffer Recording ── -->
                <StackPanel Style="{StaticResource GroupHeader}">
                    <Rectangle Style="{StaticResource HeaderAccentBar}"/>
                    <TextBlock Text="BUFFER RECORDING" Style="{StaticResource HeaderText}"/>
                </StackPanel>
                <Border Style="{StaticResource GlassCard}" Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="48"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="Past buffer duration:"
                                   Style="{StaticResource SettingsLabel}"/>
                        <Slider x:Name="BufferDurationSlider"
                                Grid.Column="1"
                                Minimum="0.5"
                                Maximum="60"
                                TickFrequency="0.5"
                                IsSnapToTickEnabled="True"
                                VerticalAlignment="Center"
                                ValueChanged="BufferDurationSlider_Changed"/>
                        <TextBlock x:Name="BufferDurationLabel"
                                   Grid.Column="2"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   Text="10s"
                                   Foreground="#FFB0B0CC"/>
                    </Grid>
                </Border>

                <!-- ── Buffer Trigger Hotkey ── -->
                <StackPanel Style="{StaticResource GroupHeader}">
                    <Rectangle Style="{StaticResource HeaderAccentBar}"/>
                    <TextBlock Text="BUFFER TRIGGER HOTKEY" Style="{StaticResource HeaderText}"/>
                </StackPanel>
                <Border Style="{StaticResource GlassCard}" Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="Modifiers:"
                                   Style="{StaticResource SettingsLabel}"/>
                        <StackPanel Grid.Row="0" Grid.Column="1"
                                    Orientation="Horizontal">
                            <CheckBox x:Name="ModCtrl"  Content="Ctrl"  Margin="0,0,14,0"/>
                            <CheckBox x:Name="ModAlt"   Content="Alt"   Margin="0,0,14,0"/>
                            <CheckBox x:Name="ModShift" Content="Shift"/>
                        </StackPanel>

                        <TextBlock Grid.Row="2" Grid.Column="0"
                                   Text="Key (click to capture):"
                                   Style="{StaticResource SettingsLabel}"/>
                        <TextBox x:Name="HotkeyKeyBox"
                                 Grid.Row="2" Grid.Column="1"
                                 IsReadOnly="True"
                                 Cursor="Hand"
                                 ToolTip="Click then press any key to assign"
                                 PreviewKeyDown="HotkeyKeyBox_PreviewKeyDown"
                                 GotFocus="HotkeyKeyBox_GotFocus"
                                 LostFocus="HotkeyKeyBox_LostFocus"/>
                    </Grid>
                </Border>

                <!-- ── Auto-Cleanup ── -->
                <StackPanel Style="{StaticResource GroupHeader}">
                    <Rectangle Style="{StaticResource HeaderAccentBar}"/>
                    <TextBlock Text="AUTO-CLEANUP" Style="{StaticResource HeaderText}"/>
                </StackPanel>
                <Border Style="{StaticResource GlassCard}" Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="40"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="Max recordings:"
                                   Style="{StaticResource SettingsLabel}"/>
                        <Slider x:Name="MaxRecordsSlider"
                                Grid.Column="1"
                                Minimum="0"
                                Maximum="500"
                                TickFrequency="5"
                                IsSnapToTickEnabled="True"
                                VerticalAlignment="Center"
                                ValueChanged="MaxRecordsSlider_Changed"/>
                        <TextBlock x:Name="MaxRecordsLabel"
                                   Grid.Column="2"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   Text="∞"
                                   Foreground="#FFB0B0CC"
                                   ToolTip="0 = unlimited. Favorites are never auto-deleted."/>
                    </Grid>
                </Border>

                <!-- ── Font Variant ── -->
                <StackPanel Style="{StaticResource GroupHeader}">
                    <Rectangle Style="{StaticResource HeaderAccentBar}"/>
                    <TextBlock Text="FONT VARIANT" Style="{StaticResource HeaderText}"/>
                </StackPanel>
                <Border Style="{StaticResource GlassCard}" Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="App font:"
                                   Style="{StaticResource SettingsLabel}"/>
                        <ComboBox x:Name="FontVariantCombo"
                                  Grid.Column="1"/>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- OK / Cancel -->
        <Border Grid.Row="1"
                Margin="0,14,0,0"
                Padding="0,12,0,0"
                BorderBrush="#14FFFFFF"
                BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="OK"
                        Width="88"
                        Margin="0,0,10,0"
                        Click="OkButton_Click"
                        IsDefault="True"
                        Background="#FF1A2E1A"
                        BorderBrush="#404CAF50"
                        Foreground="#FF9ECC9E"/>
                <Button Content="Cancel"
                        Width="88"
                        Click="CancelButton_Click"
                        IsCancel="True"/>
            </StackPanel>
        </Border>
        </Grid>
    </Grid>
</Window>
