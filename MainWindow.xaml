<Window x:Class="PaDDY.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:PaDDY.Controls"
        Title="PaDDY"
        Icon="PaDDY.ico"
        Height="700"
        Width="1280"
        MinWidth="1280"
        MinHeight="450"
        Background="#FF1E1E1E"
        Foreground="#FFE0E0E0"
        FontFamily="Segoe UI">

    <Window.Resources>
        <!-- Dark style for ComboBox -->
        <Style TargetType="ComboBox">
            <Setter Property="Background"
                    Value="#FF262626"/>
            <Setter Property="Foreground"
                    Value="#FFF2F2F2"/>
            <Setter Property="BorderBrush"
                    Value="#FF555555"/>
            <Setter Property="Height"
                    Value="28"/>
            <Setter Property="Padding"
                    Value="6,3"/>
            <Setter Property="VerticalContentAlignment"
                    Value="Center"/>
            <Setter Property="HorizontalContentAlignment"
                    Value="Left"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground"
                                Value="#FFF2F2F2"/>
                        <Setter Property="Background"
                                Value="#FF1F1F1F"/>
                        <Setter Property="Padding"
                                Value="8,5"/>
                        <Setter Property="HorizontalContentAlignment"
                                Value="Left"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="Bd"
                                            Background="{TemplateBinding Background}"
                                            BorderThickness="0"
                                            Padding="{TemplateBinding Padding}"
                                            SnapsToDevicePixels="True">
                                        <ContentPresenter
                                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                            SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted"
                                                Value="True">
                                            <Setter TargetName="Bd"
                                                    Property="Background"
                                                    Value="#FF3E4A57"/>
                                            <Setter Property="Foreground"
                                                    Value="#FFFFFFFF"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected"
                                                Value="True">
                                            <Setter TargetName="Bd"
                                                    Property="Background"
                                                    Value="#FF2F6F9F"/>
                                            <Setter Property="Foreground"
                                                    Value="#FFFFFFFF"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled"
                                                Value="False">
                                            <Setter Property="Foreground"
                                                    Value="#FF888888"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <!-- Closed-box: dark border + background -->
                            <ToggleButton x:Name="ToggleButton"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Style>
                                    <Style TargetType="ToggleButton">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ToggleButton">
                                                    <Border x:Name="Bd"
                                                            Background="{TemplateBinding Background}"
                                                            BorderBrush="#FF555555"
                                                            BorderThickness="1"
                                                            CornerRadius="2">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition/>
                                                                <ColumnDefinition Width="20"/>
                                                            </Grid.ColumnDefinitions>
                                                            <!-- arrow -->
                                                            <Path Grid.Column="1"
                                                                  Width="10"
                                                                    Height="6"
                                                                  HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"
                                                                  Fill="#FFB0B0B0"
                                                                  Data="M 0 0 L 10 0 L 5 6 Z"/>
                                                        </Grid>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsChecked"
                                                                Value="True">
                                                            <Setter TargetName="Bd"
                                                                    Property="BorderBrush"
                                                                    Value="#FF4A90D9"/>
                                                        </Trigger>
                                                        <Trigger Property="IsMouseOver"
                                                                Value="True">
                                                            <Setter TargetName="Bd"
                                                                    Property="Background"
                                                                    Value="#FF303030"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Setter Property="Background"
                                                Value="#FF262626"/>
                                    </Style>
                                </ToggleButton.Style>
                            </ToggleButton>

                            <!-- Selected text -->
                            <ContentPresenter x:Name="ContentSite"
                                              Margin="8,0,26,0"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"/>

                            <!-- Popup list -->
                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Border Background="#FF1F1F1F"
                                        BorderBrush="#FF5C5C5C"
                                        BorderThickness="1"
                                        CornerRadius="2"
                                        MinWidth="{TemplateBinding ActualWidth}"
                                        MaxHeight="300"
                                        SnapsToDevicePixels="True">
                                    <ScrollViewer SnapsToDevicePixels="True">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark style for ToggleButton -->
        <Style TargetType="ToggleButton">
            <Setter Property="Foreground"
                    Value="White"/>
            <Setter Property="BorderThickness"
                    Value="1"/>
            <Setter Property="Padding"
                    Value="12,4"/>
            <Setter Property="Height"
                    Value="32"/>
            <Setter Property="FontWeight"
                    Value="Bold"/>
            <Setter Property="Cursor"
                    Value="Hand"/>
            <Setter Property="Content"
                    Value="▶  Start Monitoring"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd"
                                Background="#FF2E7D32"
                                BorderBrush="#FF388E3C"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="0"
                                                  BlurRadius="0"
                                                  Color="#FFC62828"
                                                  Opacity="0"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FFC62828"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#FFD35E5E"/>
                                <Setter Property="Content" Value="Stop Monitoring"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard x:Name="GlowPulse">
                                        <Storyboard>
                                            <DoubleAnimation
                                                Storyboard.TargetName="Bd"
                                                Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                                                From="4" To="18"
                                                Duration="0:0:1.2"
                                                AutoReverse="True"
                                                RepeatBehavior="Forever"/>
                                            <DoubleAnimation
                                                Storyboard.TargetName="Bd"
                                                Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                                From="0.4" To="0.9"
                                                Duration="0:0:1.2"
                                                AutoReverse="True"
                                                RepeatBehavior="Forever"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <StopStoryboard BeginStoryboardName="GlowPulse"/>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Label style -->
        <Style TargetType="Label">
            <Setter Property="Foreground"
                    Value="#FFB0B0B0"/>
            <Setter Property="VerticalAlignment"
                    Value="Center"/>
            <Setter Property="Padding"
                    Value="0"/>
        </Style>

        <!-- Slider style -->
        <Style TargetType="Slider">
            <Setter Property="VerticalAlignment"
                    Value="Center"/>
            <Setter Property="Foreground"
                    Value="#FF4CAF50"/>
        </Style>

        <!-- Section header style -->
        <Style x:Key="SectionLabel"
                TargetType="TextBlock">
            <Setter Property="Foreground"
                    Value="#FF9E9E9E"/>
            <Setter Property="FontSize"
                    Value="10"/>
            <Setter Property="VerticalAlignment"
                    Value="Center"/>
        </Style>

        <!-- Dark Button style -->
        <Style TargetType="Button">
            <Setter Property="Background"
                    Value="#FF353535"/>
            <Setter Property="Foreground"
                    Value="#FFE0E0E0"/>
            <Setter Property="BorderBrush"
                    Value="#FF555555"/>
            <Setter Property="BorderThickness"
                    Value="1"/>
            <Setter Property="Padding"
                    Value="10,4"/>
            <Setter Property="Height"
                    Value="28"/>
            <Setter Property="Cursor"
                    Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                    VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                    Value="True">
                                <Setter TargetName="Bd"
                                        Property="Background"
                                        Value="#FF454545"/>
                            </Trigger>
                            <Trigger Property="IsPressed"
                                    Value="True">
                                <Setter TargetName="Bd"
                                        Property="Background"
                                        Value="#FF252525"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Row 0: Device + Controls toolbar -->
            <RowDefinition Height="Auto"/>
            <!-- Row 1: Detection controls -->
            <RowDefinition Height="Auto"/>
            <!-- Row 2: Status + RMS meters -->
            <RowDefinition Height="*"/>
            <!-- Row 3: Pad panel -->
        </Grid.RowDefinitions>

        <!-- ───────────── Row 0: Device + Controls toolbar ───────────── -->
        <Border Grid.Row="0"
                Background="#FF252525"
                BorderBrush="#FF333333"
                BorderThickness="0,0,0,1"
                Padding="12,8">
            <WrapPanel Orientation="Horizontal"
                    VerticalAlignment="Center">

                <!-- Start/Stop toggle -->
                <ToggleButton x:Name="MonitorToggle"
                              Margin="0,0,8,0"
                              Checked="MonitorToggle_Checked"
                              Unchecked="MonitorToggle_Unchecked"/>

                <!-- Folder -->
                <Button Margin="0,0,8,0"
                    Padding="8,0"
                    ToolTip="Open recordings folder in Explorer"
                    Click="OpenFolderButton_Click">
                    <TextBlock Text="&#x1F4C1;"
                           FontFamily="Segoe UI Emoji"
                           FontSize="15"/>
                </Button>

                <!-- Settings + About -->
                <Button Content="⚙ Settings"
                        Margin="0,0,6,0"
                        Click="SettingsButton_Click"/>
                <Button Content="ℹ About"
                        Click="AboutButton_Click"/>

                <!-- Separator -->
                <Rectangle Width="1"
                           Height="20"
                           Fill="#FF444444"
                           Margin="12,0,12,0"
                           VerticalAlignment="Center"/>

                <!-- Input device -->
                <StackPanel Orientation="Horizontal"
                        Margin="0,0,12,0">
                    <TextBlock Text="🎚 Source:"
                            Style="{StaticResource SectionLabel}"
                            Margin="0,0,6,0"/>
                    <ComboBox x:Name="CaptureSourceCombo"
                            Width="145"
                              SelectionChanged="CaptureSourceCombo_SelectionChanged"
                            Margin="0,0,10,0"/>

                    <TextBlock x:Name="InputDeviceLabel"
                            Text="🎙 Mic:"
                            Style="{StaticResource SectionLabel}"
                            Margin="0,0,6,0"/>
                    <ComboBox x:Name="InputDeviceCombo"
                            Width="175"
                              SelectionChanged="InputDeviceCombo_SelectionChanged"/>

                    <TextBlock x:Name="LoopbackDeviceLabel"
                            Text="🖥 Loopback:"
                            Style="{StaticResource SectionLabel}"
                            Margin="10,0,6,0"
                            Visibility="Collapsed"/>
                    <ComboBox x:Name="LoopbackDeviceCombo"
                            Width="210"
                            Visibility="Collapsed"
                              SelectionChanged="LoopbackDeviceCombo_SelectionChanged"/>
                </StackPanel>

                <!-- Output device -->
                <StackPanel Orientation="Horizontal"
                        Margin="0,0,12,0">
                    <TextBlock Text="🔊 Output:"
                            Style="{StaticResource SectionLabel}"
                            Margin="0,0,6,0"/>
                    <ComboBox x:Name="OutputDeviceCombo"
                            Width="165"
                              SelectionChanged="OutputDeviceCombo_SelectionChanged"/>
                </StackPanel>

                <!-- Pad listen output -->
                <StackPanel Orientation="Horizontal"
                        Margin="0,0,12,0"
                        VerticalAlignment="Center">
                    <CheckBox x:Name="ListenOutputEnabledCheck"
                              Content="🔈 Pad Listen"
                              Foreground="#FFE0E0E0"
                              VerticalAlignment="Center"
                              Margin="0,0,8,0"
                              Checked="ListenOutputEnabledCheck_Changed"
                              Unchecked="ListenOutputEnabledCheck_Changed"/>
                    <ComboBox x:Name="ListenOutputDeviceCombo"
                            Width="170"
                              ToolTip="Playback device used when clicking a recording pad"
                              SelectionChanged="ListenOutputDeviceCombo_SelectionChanged"/>
                </StackPanel>

                <!-- Recording mode -->
                <StackPanel Orientation="Horizontal"
                        Margin="0,0,12,0"
                        VerticalAlignment="Center">
                    <TextBlock Text="⚙ Mode:"
                            Style="{StaticResource SectionLabel}"
                            Margin="0,0,6,0"/>
                    <ComboBox x:Name="RecordingModeCombo"
                            Width="120"
                              SelectionChanged="RecordingModeCombo_SelectionChanged"
                              ToolTip="AutoVAD: auto-detect speech. Key Buffer: save last N seconds on hotkey press."/>
                </StackPanel>
            </WrapPanel>
        </Border>

        <!-- ───────────── Row 1: Sensitivity + Silence + KeyBuffer hint ───────────── -->
        <Border Grid.Row="1"
                Background="#FF222222"
                BorderBrush="#FF333333"
                BorderThickness="0,0,0,1"
                Padding="12,6">
            <WrapPanel Orientation="Horizontal">

                <!-- Sensitivity -->
                <StackPanel Orientation="Horizontal"
                        Margin="0,0,24,0">
                    <TextBlock Text="🎚 Sensitivity:"
                            Style="{StaticResource SectionLabel}"
                            Margin="0,0,8,0"/>
                    <Slider x:Name="SensitivitySlider"
                            Width="160"
                            Minimum="1"
                            Maximum="99"
                            Value="30"
                            TickFrequency="5"
                            ValueChanged="SensitivitySlider_ValueChanged"/>
                    <TextBlock x:Name="SensitivityValueLabel"
                               Text="30"
                               Style="{StaticResource SectionLabel}"
                               Margin="8,0,0,0"
                               Width="28"/>
                </StackPanel>

                <!-- Silence timeout -->
                <StackPanel Orientation="Horizontal"
                        Margin="0,0,24,0">
                    <TextBlock Text="⏱ Silence:"
                            Style="{StaticResource SectionLabel}"
                            Margin="0,0,8,0"/>
                    <Slider x:Name="SilenceSlider"
                            Width="130"
                            Minimum="300"
                            Maximum="2000"
                            Value="700"
                            TickFrequency="100"
                            ValueChanged="SilenceSlider_ValueChanged"/>
                    <TextBlock x:Name="SilenceValueLabel"
                               Text="0.70s"
                               Style="{StaticResource SectionLabel}"
                               Margin="8,0,0,0"
                               Width="36"/>
                </StackPanel>

                <!-- Key Buffer hint (visible in KeyBuffer mode) -->
                <StackPanel x:Name="KeyBufferHint"
                            Orientation="Horizontal"
                            Visibility="Collapsed"
                            VerticalAlignment="Center">
                    <TextBlock Text="⌨ Buffer hotkey:"
                               Style="{StaticResource SectionLabel}"
                               Margin="0,0,6,0"/>
                    <TextBlock x:Name="HotkeyLabel"
                               Text="Ctrl+F9"
                               Foreground="#FFFFC107"
                               FontSize="11"
                               FontWeight="Bold"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Separator -->
                <Rectangle Width="1"
                           Height="16"
                           Fill="#FF444444"
                           Margin="8,0,16,0"
                           VerticalAlignment="Center"/>

                <!-- Input Volume -->
                <StackPanel Orientation="Horizontal"
                        Margin="0,0,20,0">
                    <TextBlock Text="🔊 Input:"
                            Style="{StaticResource SectionLabel}"
                            Margin="0,0,6,0"/>
                    <Slider x:Name="InputVolumeSlider"
                            Width="100"
                            Minimum="0"
                            Maximum="100"
                            Value="80"
                            TickFrequency="5"
                            ValueChanged="InputVolumeSlider_ValueChanged"/>
                    <TextBlock x:Name="InputVolumeValueLabel"
                               Text="80"
                               Style="{StaticResource SectionLabel}"
                               Margin="6,0,0,0"
                               Width="28"/>
                </StackPanel>

                <!-- Output Volume -->
                <StackPanel Orientation="Horizontal"
                        Margin="0,0,20,0">
                    <TextBlock Text="🔊 Output:"
                            Style="{StaticResource SectionLabel}"
                            Margin="0,0,6,0"/>
                    <Slider x:Name="OutputVolumeSlider"
                            Width="100"
                            Minimum="0"
                            Maximum="100"
                            Value="100"
                            TickFrequency="5"
                            ValueChanged="OutputVolumeSlider_ValueChanged"/>
                    <TextBlock x:Name="OutputVolumeValueLabel"
                               Text="100"
                               Style="{StaticResource SectionLabel}"
                               Margin="6,0,0,0"
                               Width="28"/>
                </StackPanel>

                <!-- Pad Listen Volume -->
                <StackPanel Orientation="Horizontal"
                        Margin="0,0,0,0">
                    <TextBlock Text="🔈 Pad Listen:"
                            Style="{StaticResource SectionLabel}"
                            Margin="0,0,6,0"/>
                    <Slider x:Name="PadListenVolumeSlider"
                            Width="100"
                            Minimum="0"
                            Maximum="100"
                            Value="100"
                            TickFrequency="5"
                            ValueChanged="PadListenVolumeSlider_ValueChanged"/>
                    <TextBlock x:Name="PadListenVolumeValueLabel"
                               Text="100"
                               Style="{StaticResource SectionLabel}"
                               Margin="6,0,0,0"
                               Width="28"/>
                </StackPanel>
            </WrapPanel>
        </Border>

        <!-- ───────────── Row 2: Status + IN/OUT RMS meters ───────────── -->
        <Border Grid.Row="2"
                Background="#FF1A1A1A"
                Padding="12,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <!-- IN/OUT labels -->
                    <ColumnDefinition Width="*"/>
                    <!-- Meter bars -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- dB + peak -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Status -->
                </Grid.ColumnDefinitions>

                <!-- IN / OUT labels -->
                <StackPanel Grid.Column="0"
                            Orientation="Vertical"
                            VerticalAlignment="Center"
                            Margin="0,0,6,0">
                    <TextBlock Text="IN"
                               Foreground="#FF9E9E9E"
                               FontSize="9"
                               FontWeight="Bold"
                               HorizontalAlignment="Right"
                               Height="24"
                               Padding="0,4,0,0"/>
                    <TextBlock Text="OUT"
                               Foreground="#FF42A5F5"
                               FontSize="9"
                               FontWeight="Bold"
                               HorizontalAlignment="Right"
                               Height="24"
                               Margin="0,5,0,0"
                               Padding="0,4,0,0"/>
                </StackPanel>

                <!-- Meter bars column -->
                <StackPanel Grid.Column="1"
                        Orientation="Vertical"
                        VerticalAlignment="Center">
                    <!-- Input L channel -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="L"
                                Grid.Column="0"
                                   Foreground="#FF9E9E9E"
                                FontSize="9"
                                   VerticalAlignment="Center"
                                HorizontalAlignment="Center"/>
                        <Grid Grid.Column="1" ClipToBounds="True">
                            <Rectangle Height="11">
                                <Rectangle.Fill>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#FF2E7D32" Offset="0.0"/>
                                        <GradientStop Color="#FF4CAF50" Offset="0.35"/>
                                        <GradientStop Color="#FFFDD835" Offset="0.70"/>
                                        <GradientStop Color="#FFFF9800" Offset="0.85"/>
                                        <GradientStop Color="#FFF44336" Offset="0.95"/>
                                        <GradientStop Color="#FFD50000" Offset="1.0"/>
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                            </Rectangle>
                            <Rectangle x:Name="MeterOverlayL"
                                       Height="11"
                                       Fill="#FF333333"
                                       HorizontalAlignment="Right"
                                       Width="1000"/>
                            <Canvas x:Name="ThresholdCanvas"
                                    Height="11">
                                <Rectangle x:Name="ThresholdLine"
                                           Width="2"
                                        Height="11"
                                           Fill="#FFFF9800"
                                           Canvas.Top="0"/>
                            </Canvas>
                        </Grid>
                    </Grid>
                    <!-- Input R channel -->
                    <Grid x:Name="RmsMeterRRow"
                            Margin="0,2,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="R"
                                Grid.Column="0"
                                   Foreground="#FF9E9E9E"
                                FontSize="9"
                                   VerticalAlignment="Center"
                                HorizontalAlignment="Center"/>
                        <Grid Grid.Column="1" ClipToBounds="True">
                            <Rectangle Height="11">
                                <Rectangle.Fill>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#FF2E7D32" Offset="0.0"/>
                                        <GradientStop Color="#FF4CAF50" Offset="0.35"/>
                                        <GradientStop Color="#FFFDD835" Offset="0.70"/>
                                        <GradientStop Color="#FFFF9800" Offset="0.85"/>
                                        <GradientStop Color="#FFF44336" Offset="0.95"/>
                                        <GradientStop Color="#FFD50000" Offset="1.0"/>
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                            </Rectangle>
                            <Rectangle x:Name="MeterOverlayR"
                                       Height="11"
                                       Fill="#FF333333"
                                       HorizontalAlignment="Right"
                                       Width="1000"/>
                            <Canvas x:Name="ThresholdCanvasR"
                                    Height="11">
                                <Rectangle x:Name="ThresholdLineR"
                                           Width="2"
                                        Height="11"
                                           Fill="#FFFF9800"
                                           Canvas.Top="0"/>
                            </Canvas>
                        </Grid>
                    </Grid>

                    <!-- Separator -->
                    <Rectangle Height="1"
                               Fill="#FF333333"
                               Margin="14,3,0,3"/>

                    <!-- Output L channel -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="L"
                                Grid.Column="0"
                                   Foreground="#FF616161"
                                FontSize="9"
                                   VerticalAlignment="Center"
                                HorizontalAlignment="Center"/>
                        <Grid Grid.Column="1" ClipToBounds="True">
                            <Rectangle Height="11">
                                <Rectangle.Fill>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#FF1565C0" Offset="0.0"/>
                                        <GradientStop Color="#FF42A5F5" Offset="0.35"/>
                                        <GradientStop Color="#FF80DEEA" Offset="0.70"/>
                                        <GradientStop Color="#FFFDD835" Offset="0.85"/>
                                        <GradientStop Color="#FFF44336" Offset="0.95"/>
                                        <GradientStop Color="#FFD50000" Offset="1.0"/>
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                            </Rectangle>
                            <Rectangle x:Name="OutputMeterOverlayL"
                                       Height="11"
                                       Fill="#FF333333"
                                       HorizontalAlignment="Right"
                                       Width="1000"/>
                        </Grid>
                    </Grid>
                    <!-- Output R channel -->
                    <Grid Margin="0,2,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="R"
                                Grid.Column="0"
                                   Foreground="#FF616161"
                                FontSize="9"
                                   VerticalAlignment="Center"
                                HorizontalAlignment="Center"/>
                        <Grid Grid.Column="1" ClipToBounds="True">
                            <Rectangle Height="11">
                                <Rectangle.Fill>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#FF1565C0" Offset="0.0"/>
                                        <GradientStop Color="#FF42A5F5" Offset="0.35"/>
                                        <GradientStop Color="#FF80DEEA" Offset="0.70"/>
                                        <GradientStop Color="#FFFDD835" Offset="0.85"/>
                                        <GradientStop Color="#FFF44336" Offset="0.95"/>
                                        <GradientStop Color="#FFD50000" Offset="1.0"/>
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                            </Rectangle>
                            <Rectangle x:Name="OutputMeterOverlayR"
                                       Height="11"
                                       Fill="#FF333333"
                                       HorizontalAlignment="Right"
                                       Width="1000"/>
                        </Grid>
                    </Grid>
                </StackPanel>

                <!-- dB values + peak indicators -->
                <StackPanel Grid.Column="2"
                            Orientation="Vertical"
                            VerticalAlignment="Center"
                            Margin="8,0,0,0">
                    <!-- Input dB -->
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="RmsValueLabel"
                                   Text="-∞"
                                   FontSize="10"
                                   Foreground="#FF9E9E9E"
                                   Width="36"/>
                        <Border x:Name="PeakIndicatorL"
                                Width="8" Height="8"
                                CornerRadius="4"
                                Background="#FF444444"
                                VerticalAlignment="Center"
                                ToolTip="Peak clip indicator"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                        <TextBlock x:Name="RmsValueLabelR"
                                   Text="-∞"
                                   FontSize="10"
                                   Foreground="#FF9E9E9E"
                                   Width="36"/>
                        <Border x:Name="PeakIndicatorR"
                                Width="8" Height="8"
                                CornerRadius="4"
                                Background="#FF444444"
                                VerticalAlignment="Center"
                                ToolTip="Peak clip indicator"/>
                    </StackPanel>
                    <!-- Output dB -->
                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                        <TextBlock x:Name="OutputRmsValueLabel"
                                   Text="-∞"
                                   FontSize="10"
                                   Foreground="#FF616161"
                                   Width="36"/>
                        <Border x:Name="OutputPeakIndicatorL"
                                Width="8" Height="8"
                                CornerRadius="4"
                                Background="#FF444444"
                                VerticalAlignment="Center"
                                ToolTip="Output peak clip indicator"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                        <TextBlock x:Name="OutputRmsValueLabelR"
                                   Text="-∞"
                                   FontSize="10"
                                   Foreground="#FF616161"
                                   Width="36"/>
                        <Border x:Name="OutputPeakIndicatorR"
                                Width="8" Height="8"
                                CornerRadius="4"
                                Background="#FF444444"
                                VerticalAlignment="Center"
                                ToolTip="Output peak clip indicator"/>
                    </StackPanel>
                </StackPanel>

                <!-- Status indicator (right side) -->
                <StackPanel Grid.Column="3"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="16,0,0,0">
                    <Ellipse x:Name="StatusDot"
                             Width="10"
                             Height="10"
                             Fill="#FF757575"
                             VerticalAlignment="Center"
                             Margin="0,0,8,0"/>
                    <TextBlock x:Name="StatusLabel"
                               Text="Idle — press Start to begin"
                               FontSize="11"
                               Foreground="#FF9E9E9E"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               MaxWidth="300"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ───────────── Row 3: Favorites + Recordings pad panel ───────────── -->
        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Favorites header -->
                <RowDefinition Height="Auto"/>
                <!-- Favorites panel -->
                <RowDefinition Height="Auto"/>
                <!-- Recordings header -->
                <RowDefinition Height="*"/>
                <!-- Recordings scrollable area -->
            </Grid.RowDefinitions>

            <!-- ── Favorites header (hidden when empty) ── -->
            <Border x:Name="FavoritesHeader"
                    Grid.Row="0"
                    Background="#FF1F1C10"
                    BorderBrush="#FF3A3010"
                    BorderThickness="0,0,0,1"
                    Padding="12,5"
                    Visibility="Collapsed">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="★ FAVORITES"
                               Foreground="#FFFFC107"
                               FontSize="10"
                            FontWeight="Bold"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="FavoriteCountLabel"
                               Text=" — 0"
                               Foreground="#FFAAAAAA"
                               FontSize="10"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- ── Favorites WrapPanel ── -->
            <Border x:Name="FavoritesPanelBorder"
                    Grid.Row="1"
                    Background="#FF1A1700"
                    Visibility="Collapsed"
                    Padding="12,6,12,6">
                <WrapPanel x:Name="FavoritesPanel"
                        Orientation="Horizontal"/>
            </Border>

            <!-- ── Recordings header ── -->
            <Border Grid.Row="2"
                    Background="#FF252525"
                    Padding="12,6">
                <Grid>
                    <TextBlock Text="RECORDINGS"
                            Foreground="#FF616161"
                               FontSize="10"
                            FontWeight="Bold"
                               VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right">
                        <TextBlock x:Name="RecordingCountLabel"
                                   Text="0 clips"
                                   Foreground="#FF616161"
                                   FontSize="10"
                                   VerticalAlignment="Center"
                                   Margin="0,0,12,0"/>
                        <ComboBox x:Name="SortOrderCombo"
                                  Width="110"
                                  Height="22"
                                  Margin="0,0,8,0"
                                  ToolTip="Sort order for recordings"
                                  SelectionChanged="SortOrderCombo_SelectionChanged"/>
                        <Button Content="Clear Pads"
                                Height="22"
                                Padding="8,2"
                                Margin="0,0,6,0"
                                ToolTip="Remove pad buttons from the UI (files are kept on disk)"
                                Click="ClearPadsButton_Click"/>
                        <Button Content="🗑 Delete All Files"
                                Height="22"
                                Padding="8,2"
                                ToolTip="Permanently delete recordings from disk"
                                Click="DeleteAllFilesButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Scrollable recordings area ── -->
            <ScrollViewer Grid.Row="3"
                    VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Background="#FF1E1E1E">
                <StackPanel>
                    <WrapPanel x:Name="PadPanel"
                               Margin="12"
                               Orientation="Horizontal"/>
                    <TextBlock x:Name="EmptyHint"
                               Text="No recordings yet :( &#x0a;Start monitoring to capture any sounds!"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="#FF424242"
                               FontSize="13"
                               TextAlignment="Center"
                               Margin="0,60,0,0"/>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
