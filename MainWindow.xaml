<Window x:Class="Paddy.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:Paddy.Controls"
        Title="Paddy — Auto Voice Recorder"
        Height="650" Width="900" MinWidth="600" MinHeight="400"
        Background="#FF1E1E1E"
        Foreground="#FFE0E0E0"
        FontFamily="Segoe UI">

    <Window.Resources>
        <!-- Dark style for ComboBox -->
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#FF262626"/>
            <Setter Property="Foreground" Value="#FFF2F2F2"/>
            <Setter Property="BorderBrush" Value="#FF555555"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="#FFF2F2F2"/>
                        <Setter Property="Background" Value="#FF1F1F1F"/>
                        <Setter Property="Padding" Value="8,5"/>
                        <Setter Property="HorizontalContentAlignment" Value="Left"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="Bd"
                                            Background="{TemplateBinding Background}"
                                            BorderThickness="0"
                                            Padding="{TemplateBinding Padding}"
                                            SnapsToDevicePixels="True">
                                        <ContentPresenter
                                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                            SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#FF3E4A57"/>
                                            <Setter Property="Foreground" Value="#FFFFFFFF"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#FF2F6F9F"/>
                                            <Setter Property="Foreground" Value="#FFFFFFFF"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Foreground" Value="#FF888888"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <!-- Closed-box: dark border + background -->
                            <ToggleButton x:Name="ToggleButton"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Style>
                                    <Style TargetType="ToggleButton">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ToggleButton">
                                                    <Border x:Name="Bd"
                                                            Background="{TemplateBinding Background}"
                                                            BorderBrush="#FF555555"
                                                            BorderThickness="1"
                                                            CornerRadius="2">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition/>
                                                                <ColumnDefinition Width="20"/>
                                                            </Grid.ColumnDefinitions>
                                                            <!-- arrow -->
                                                            <Path Grid.Column="1"
                                                                  Width="10" Height="6"
                                                                  HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"
                                                                  Fill="#FFB0B0B0"
                                                                  Data="M 0 0 L 10 0 L 5 6 Z"/>
                                                        </Grid>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsChecked" Value="True">
                                                            <Setter TargetName="Bd" Property="BorderBrush" Value="#FF4A90D9"/>
                                                        </Trigger>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="#FF303030"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Setter Property="Background" Value="#FF262626"/>
                                    </Style>
                                </ToggleButton.Style>
                            </ToggleButton>

                            <!-- Selected text -->
                            <ContentPresenter x:Name="ContentSite"
                                              Margin="8,0,26,0"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"/>

                            <!-- Popup list -->
                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Border Background="#FF1F1F1F"
                                        BorderBrush="#FF5C5C5C"
                                        BorderThickness="1"
                                        CornerRadius="2"
                                        MinWidth="{TemplateBinding ActualWidth}"
                                        MaxHeight="300"
                                        SnapsToDevicePixels="True">
                                    <ScrollViewer SnapsToDevicePixels="True">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark style for ToggleButton -->
        <Style TargetType="ToggleButton">
            <Setter Property="Background" Value="#FF2E7D32"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#FF388E3C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="#FFC62828"/>
                    <Setter Property="BorderBrush" Value="#FFD32F2F"/>
                    <Setter Property="Content" Value="⏹  Stop Monitoring"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.9"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Label style -->
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#FFB0B0B0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <!-- Slider style -->
        <Style TargetType="Slider">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="#FF4CAF50"/>
        </Style>

        <!-- Section header style -->
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FF9E9E9E"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- toolbar -->
            <RowDefinition Height="Auto"/>   <!-- detection controls -->
            <RowDefinition Height="Auto"/>   <!-- status + RMS meter -->
            <RowDefinition Height="*"/>      <!-- pad panel -->
        </Grid.RowDefinitions>

        <!-- ───────────── Row 0: Device + Controls toolbar ───────────── -->
        <Border Grid.Row="0" Background="#FF252525" BorderBrush="#FF333333"
                BorderThickness="0,0,0,1" Padding="12,8">
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">

                <!-- Input device -->
                <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                    <TextBlock Text="🎚 Source:" Style="{StaticResource SectionLabel}" Margin="0,0,6,0"/>
                    <ComboBox x:Name="CaptureSourceCombo" Width="150"
                              SelectionChanged="CaptureSourceCombo_SelectionChanged" Margin="0,0,10,0"/>

                    <TextBlock x:Name="InputDeviceLabel" Text="🎙 Mic:" Style="{StaticResource SectionLabel}" Margin="0,0,6,0"/>
                    <ComboBox x:Name="InputDeviceCombo" Width="180"
                              SelectionChanged="InputDeviceCombo_SelectionChanged"/>

                    <TextBlock x:Name="LoopbackDeviceLabel" Text="🖥 Loopback:" Style="{StaticResource SectionLabel}" Margin="10,0,6,0" Visibility="Collapsed"/>
                    <ComboBox x:Name="LoopbackDeviceCombo" Width="220" Visibility="Collapsed"
                              SelectionChanged="LoopbackDeviceCombo_SelectionChanged"/>
                </StackPanel>

                <!-- Output device -->
                <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                    <TextBlock Text="🔊 Output:" Style="{StaticResource SectionLabel}" Margin="0,0,6,0"/>
                    <ComboBox x:Name="OutputDeviceCombo" Width="175"
                              SelectionChanged="OutputDeviceCombo_SelectionChanged"/>
                </StackPanel>

                <!-- Pad listen output -->
                <StackPanel Orientation="Horizontal" Margin="0,0,16,0" VerticalAlignment="Center">
                    <CheckBox x:Name="ListenOutputEnabledCheck"
                              Content="🔈 Pad Listen"
                              Foreground="#FFE0E0E0"
                              VerticalAlignment="Center"
                              Margin="0,0,8,0"
                              Checked="ListenOutputEnabledCheck_Changed"
                              Unchecked="ListenOutputEnabledCheck_Changed"/>
                    <ComboBox x:Name="ListenOutputDeviceCombo" Width="180" ToolTip="Playback device used when clicking a recording pad"
                              SelectionChanged="ListenOutputDeviceCombo_SelectionChanged"/>
                </StackPanel>

                <!-- Start/Stop toggle -->
                <ToggleButton x:Name="MonitorToggle"
                              Content="▶  Start Monitoring"
                              Margin="0,0,12,0"
                              Checked="MonitorToggle_Checked"
                              Unchecked="MonitorToggle_Unchecked"/>

                <!-- Folder button + label -->
                <Button Content="📁 Save Folder" Margin="0,0,6,0"
                        Click="ChangeFolderButton_Click"/>
                <TextBlock x:Name="FolderLabel"
                           Text="./recordings"
                           VerticalAlignment="Center"
                           Foreground="#FF78909C"
                           FontSize="11"
                           TextTrimming="CharacterEllipsis"
                           MaxWidth="200"/>
            </WrapPanel>
        </Border>

        <!-- ───────────── Row 1: Sensitivity + Silence Timeout ───────────── -->
        <Border Grid.Row="1" Background="#FF222222" BorderBrush="#FF333333"
                BorderThickness="0,0,0,1" Padding="12,6">
            <WrapPanel Orientation="Horizontal">

                <!-- Sensitivity -->
                <StackPanel Orientation="Horizontal" Margin="0,0,24,0">
                    <TextBlock Text="🎚 Sensitivity:" Style="{StaticResource SectionLabel}" Margin="0,0,8,0"/>
                    <Slider x:Name="SensitivitySlider"
                            Width="160"
                            Minimum="1" Maximum="99" Value="30"
                            TickFrequency="5"
                            ValueChanged="SensitivitySlider_ValueChanged"/>
                    <TextBlock x:Name="SensitivityValueLabel"
                               Text="30"
                               Style="{StaticResource SectionLabel}"
                               Margin="8,0,0,0"
                               Width="28"/>
                </StackPanel>

                <!-- Silence timeout -->
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="⏱ Silence:" Style="{StaticResource SectionLabel}" Margin="0,0,8,0"/>
                    <Slider x:Name="SilenceSlider"
                            Width="130"
                            Minimum="300" Maximum="2000" Value="700"
                            TickFrequency="100"
                            ValueChanged="SilenceSlider_ValueChanged"/>
                    <TextBlock x:Name="SilenceValueLabel"
                               Text="0.70s"
                               Style="{StaticResource SectionLabel}"
                               Margin="8,0,0,0"
                               Width="36"/>
                </StackPanel>
            </WrapPanel>
        </Border>

        <!-- ───────────── Row 2: Status bar + RMS meter ───────────── -->
        <Border Grid.Row="2" Background="#FF1A1A1A" Padding="12,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Status dot + text -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,12,0">
                    <Ellipse x:Name="StatusDot" Width="10" Height="10"
                             Fill="#FF757575" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock x:Name="StatusLabel"
                               Text="Idle — press Start to begin"
                               FontSize="12"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- RMS meter with threshold marker -->
                <Grid Grid.Column="1">
                    <!-- Background track -->
                    <ProgressBar x:Name="RmsMeter"
                                 Height="14"
                                 Minimum="0" Maximum="100" Value="0"
                                 Foreground="#FF4CAF50"
                                 Background="#FF333333"
                                 BorderThickness="0"/>

                    <!-- Threshold marker line -->
                    <Canvas x:Name="ThresholdCanvas" Height="14">
                        <Rectangle x:Name="ThresholdLine"
                                   Width="2" Height="14"
                                   Fill="#FFFF9800"
                                   Canvas.Top="0"/>
                    </Canvas>
                </Grid>

                <!-- RMS value -->
                <TextBlock x:Name="RmsValueLabel"
                           Grid.Column="2"
                           Text="0"
                           FontSize="10"
                           Foreground="#FF9E9E9E"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"
                           Width="30"/>
            </Grid>
        </Border>

        <!-- ───────────── Row 3: Pad panel ───────────── -->
        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Pad panel header -->
            <Border Grid.Row="0" Background="#FF252525" Padding="12,6">
                <Grid>
                    <TextBlock Text="RECORDINGS" Foreground="#FF616161"
                               FontSize="10" FontWeight="Bold"
                               VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock x:Name="RecordingCountLabel"
                                   Text="0 clips"
                                   Foreground="#FF616161"
                                   FontSize="10"
                                   VerticalAlignment="Center"
                                   Margin="0,0,12,0"/>
                        <Button Content="Clear All" Height="22" Padding="8,2"
                                Click="ClearAllButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Scrollable pad area -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Background="#FF1E1E1E">
                <StackPanel>
                    <WrapPanel x:Name="PadPanel"
                               Margin="12"
                               Orientation="Horizontal"/>
                    <!-- Empty state hint -->
                    <TextBlock x:Name="EmptyHint"
                               Text="No recordings yet.&#x0a;Press ▶ Start Monitoring and speak into your microphone."
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="#FF424242"
                               FontSize="13"
                               TextAlignment="Center"
                               Margin="0,60,0,0"/>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
