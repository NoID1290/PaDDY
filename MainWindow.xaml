<Window x:Class="PaDDY.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:PaDDY.Controls"
        Title="PaDDY"
        Icon="PaDDY.ico"
        Height="740"
        Width="1380"
        MinWidth="1100"
        MinHeight="600"
        Background="#FF0D0D14"
        Foreground="#FFE0E8F0"
        FontFamily="Segoe UI">

    <Window.Resources>

        <!-- Monitor toggle: green (idle) → red+pulse (active) -->
        <Style x:Key="MonitorToggleStyle" TargetType="ToggleButton">
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="22,0"/>
            <Setter Property="Width"           Value="185"/>
            <Setter Property="Height"          Value="38"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Content"         Value="▶  Start Monitoring"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#FF388E3C" Offset="0"/>
                                    <GradientStop Color="#FF2E7D32" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.BorderBrush>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#FF66BB6A" Offset="0"/>
                                    <GradientStop Color="#FF388E3C" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.BorderBrush>
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="0" BlurRadius="0"
                                                  Color="#FF55DD55" Opacity="0"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#FFD32F2F" Offset="0"/>
                                            <GradientStop Color="#FFC62828" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="Bd" Property="BorderBrush">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#FFEF5350" Offset="0"/>
                                            <GradientStop Color="#FFD32F2F" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Content" Value="■  Stop Monitoring"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard x:Name="GlowPulse">
                                        <Storyboard>
                                            <DoubleAnimation
                                                Storyboard.TargetName="Bd"
                                                Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                                                From="6" To="24" Duration="0:0:1.2"
                                                AutoReverse="True" RepeatBehavior="Forever"/>
                                            <DoubleAnimation
                                                Storyboard.TargetName="Bd"
                                                Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                                From="0.3" To="0.85" Duration="0:0:1.2"
                                                AutoReverse="True" RepeatBehavior="Forever"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <StopStoryboard BeginStoryboardName="GlowPulse"/>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.88"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.72"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Top-bar action button -->
        <Style x:Key="TopBarBtn" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Padding"    Value="14,6"/>
            <Setter Property="Height"     Value="34"/>
            <Setter Property="Background" Value="#14FFFFFF"/>
            <Setter Property="BorderBrush" Value="#18FFFFFF"/>
            <Setter Property="Foreground" Value="#FFC0C0D8"/>
        </Style>

        <!-- Icon-only top bar button -->
        <Style x:Key="TopBarIconBtn" TargetType="Button" BasedOn="{StaticResource TopBarBtn}">
            <Setter Property="Width"   Value="36"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <!-- Compact info line style for runtime details -->
        <Style x:Key="InfoLineLabel" TargetType="TextBlock">
            <Setter Property="Foreground"   Value="#FF606088"/>
            <Setter Property="FontSize"     Value="10"/>
            <Setter Property="Margin"       Value="0,2,0,0"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>

    </Window.Resources>

    <Grid x:Name="MainRootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>   <!-- Row 0: Compact top bar -->
            <RowDefinition Height="Auto"/> <!-- Row 1: Collapsible config panel -->
            <RowDefinition Height="Auto"/> <!-- Row 2: Status + RMS meters -->
            <RowDefinition Height="*"/>    <!-- Row 3: Pad panel -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════ Row 0: Compact Top Bar ═══════════════════════ -->
        <Border Grid.Row="0"
                BorderBrush="#1AFFFFFF"
                BorderThickness="0,0,0,1">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#FF141422" Offset="0"/>
                    <GradientStop Color="#FF0F0F1A" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,20,0">
                    <TextBlock Text="Pa" FontSize="20" FontWeight="Bold"
                               Foreground="#FF7070A8" VerticalAlignment="Center"/>
                    <TextBlock Text="DDY" FontSize="20" FontWeight="Bold"
                               Foreground="#FF4CAF50" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Monitor toggle -->
                <ToggleButton x:Name="MonitorToggle"
                              Grid.Column="1"
                              Style="{StaticResource MonitorToggleStyle}"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Checked="MonitorToggle_Checked"
                              Unchecked="MonitorToggle_Unchecked"/>

                <!-- Action buttons -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource TopBarIconBtn}"
                            Margin="0,0,6,0"
                            ToolTip="Open recordings folder in Explorer"
                            Click="OpenFolderButton_Click">
                        <TextBlock Text="&#x1F4C1;" FontFamily="Segoe UI Emoji" FontSize="15"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Button>
                    <Button x:Name="ConfigToggleBtn"
                            Style="{StaticResource TopBarBtn}"
                            Margin="0,0,6,0"
                            ToolTip="Show / hide configuration panel"
                            Click="ToggleConfigPanel_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="ConfigToggleText" Text="▲" FontSize="10"
                                       Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Config" FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource TopBarBtn}"
                            Content="Settings"
                            Margin="0,0,6,0"
                            Click="SettingsButton_Click"/>
                    <Button Style="{StaticResource TopBarBtn}"
                            Content="About"
                            Click="AboutButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═════════════════════ Row 1: Collapsible Config Panel ═════════════════════ -->
        <Border x:Name="ConfigPanelBorder"
                Grid.Row="1"
                Background="#FF111120"
                BorderBrush="#14FFFFFF"
                BorderThickness="0,0,0,1"
                MaxHeight="290"
                ClipToBounds="True">
            <Grid Margin="10,8,10,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ─── INPUT ─── -->
                <Border Grid.Column="0" Style="{StaticResource GlassCard}" Margin="0,0,5,0">
                    <StackPanel>
                        <TextBlock Text="INPUT" Style="{StaticResource SectionTitle}"/>

                        <!-- Source -->
                        <DockPanel Margin="0,0,0,5">
                            <TextBlock DockPanel.Dock="Left" Text="Source"
                                       Style="{StaticResource ConfigLabel}" Width="58"/>
                            <ComboBox x:Name="CaptureSourceCombo"
                                      SelectionChanged="CaptureSourceCombo_SelectionChanged"/>
                        </DockPanel>

                        <!-- Mic/Line device -->
                        <DockPanel>
                            <TextBlock x:Name="InputDeviceLabel" DockPanel.Dock="Left"
                                       Text="Mic/Line" Style="{StaticResource ConfigLabel}"
                                       Width="58" Margin="0,0,6,5" Visibility="Collapsed"/>
                            <ComboBox x:Name="InputDeviceCombo"
                                      Margin="0,0,0,5"
                                      Visibility="Collapsed"
                                      SelectionChanged="InputDeviceCombo_SelectionChanged"/>
                        </DockPanel>

                        <!-- Loopback device -->
                        <DockPanel>
                            <TextBlock x:Name="LoopbackDeviceLabel" DockPanel.Dock="Left"
                                       Text="Loopback" Style="{StaticResource ConfigLabel}"
                                       Width="58" Margin="0,0,6,5" Visibility="Collapsed"/>
                            <ComboBox x:Name="LoopbackDeviceCombo"
                                      Margin="0,0,0,5"
                                      Visibility="Collapsed"
                                      SelectionChanged="LoopbackDeviceCombo_SelectionChanged"/>
                        </DockPanel>

                        <!-- App loopback -->
                        <DockPanel>
                            <TextBlock x:Name="AppLoopbackLabel" DockPanel.Dock="Left"
                                       Text="App" Style="{StaticResource ConfigLabel}"
                                       Width="58" Margin="0,0,6,5" Visibility="Collapsed"/>
                            <Button x:Name="RefreshAppLoopbackBtn" DockPanel.Dock="Right"
                                    Content="&#x21BA;" Width="30" FontSize="14" Padding="0"
                                    Margin="4,0,0,5"
                                    Visibility="Collapsed"
                                    ToolTip="Refresh list of apps producing audio"
                                    Click="RefreshAppLoopback_Click"/>
                            <ComboBox x:Name="AppLoopbackCombo"
                                      Margin="0,0,0,5"
                                      Visibility="Collapsed"
                                      SelectionChanged="AppLoopbackCombo_SelectionChanged"/>
                        </DockPanel>

                        <!-- Input Volume -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="58"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Volume"
                                       Style="{StaticResource ConfigLabel}"/>
                            <Slider x:Name="InputVolumeSlider"
                                    Grid.Column="1"
                                    Minimum="0" Maximum="100" Value="80"
                                    TickFrequency="5"
                                    HorizontalAlignment="Stretch"
                                    ValueChanged="InputVolumeSlider_ValueChanged"/>
                            <Border Grid.Column="2" Style="{StaticResource ValueBadge}">
                                <TextBlock x:Name="InputVolumeValueLabel"
                                           Text="80" FontSize="10" Width="26" TextAlignment="Center"/>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ─── PAD MONITOR ─── -->
                <Border Grid.Column="1" Style="{StaticResource GlassCard}" Margin="5,0,5,0">
                    <StackPanel>
                        <TextBlock Text="PAD MONITOR" Style="{StaticResource SectionTitle}"/>

                        <CheckBox x:Name="ListenOutputEnabledCheck"
                                  Content="Enable monitor"
                                  Margin="0,0,0,10"
                                  Checked="ListenOutputEnabledCheck_Changed"
                                  Unchecked="ListenOutputEnabledCheck_Changed"/>

                        <DockPanel Margin="0,0,0,10">
                            <TextBlock DockPanel.Dock="Left" Text="Device"
                                       Style="{StaticResource ConfigLabel}" Width="52"/>
                            <ComboBox x:Name="ListenOutputDeviceCombo"
                                      ToolTip="Playback device used when clicking a recording pad"
                                      SelectionChanged="ListenOutputDeviceCombo_SelectionChanged"/>
                        </DockPanel>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="52"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Level"
                                       Style="{StaticResource ConfigLabel}"/>
                            <Slider x:Name="PadListenVolumeSlider"
                                    Grid.Column="1"
                                    Minimum="0" Maximum="100" Value="100"
                                    TickFrequency="5"
                                    HorizontalAlignment="Stretch"
                                    ValueChanged="PadListenVolumeSlider_ValueChanged"/>
                            <Border Grid.Column="2" Style="{StaticResource ValueBadge}">
                                <TextBlock x:Name="PadListenVolumeValueLabel"
                                           Text="100" FontSize="10" Width="26" TextAlignment="Center"/>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ─── DETECTION ─── -->
                <Border Grid.Column="2" Style="{StaticResource GlassCard}" Margin="5,0,5,0">
                    <StackPanel>
                        <TextBlock Text="DETECTION" Style="{StaticResource SectionTitle}"/>

                        <!-- Mode -->
                        <DockPanel Margin="0,0,0,8">
                            <TextBlock DockPanel.Dock="Left" Text="Mode"
                                       Style="{StaticResource ConfigLabel}" Width="72"/>
                            <ComboBox x:Name="RecordingModeCombo"
                                      SelectionChanged="RecordingModeCombo_SelectionChanged"
                                      ToolTip="AutoVAD: auto-detect speech. Key Buffer: save last N seconds on hotkey press."/>
                        </DockPanel>

                        <!-- Sensitivity -->
                        <Grid Margin="0,0,0,7">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="72"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Sensitivity"
                                       Style="{StaticResource ConfigLabel}"/>
                            <Slider x:Name="SensitivitySlider"
                                    Grid.Column="1"
                                    Minimum="1" Maximum="99" Value="30"
                                    TickFrequency="5"
                                    HorizontalAlignment="Stretch"
                                    ValueChanged="SensitivitySlider_ValueChanged"/>
                            <Border Grid.Column="2" Style="{StaticResource ValueBadge}">
                                <TextBlock x:Name="SensitivityValueLabel"
                                           Text="30" FontSize="10" Width="26" TextAlignment="Center"/>
                            </Border>
                        </Grid>

                        <!-- Silence -->
                        <Grid Margin="0,0,0,7">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="72"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Silence"
                                       Style="{StaticResource ConfigLabel}"/>
                            <Slider x:Name="SilenceSlider"
                                    Grid.Column="1"
                                    Minimum="300" Maximum="2000" Value="700"
                                    TickFrequency="100"
                                    HorizontalAlignment="Stretch"
                                    ValueChanged="SilenceSlider_ValueChanged"/>
                            <Border Grid.Column="2" Style="{StaticResource ValueBadge}">
                                <TextBlock x:Name="SilenceValueLabel"
                                           Text="0.70s" FontSize="10" Width="42" TextAlignment="Center"/>
                            </Border>
                        </Grid>

                        <!-- Hotkey hint (Key Buffer mode) -->
                        <StackPanel x:Name="KeyBufferHint"
                                    Orientation="Horizontal"
                                    Visibility="Collapsed">
                            <TextBlock Text="Hotkey" Style="{StaticResource ConfigLabel}"/>
                            <Border Style="{StaticResource ValueBadge}" Margin="2,0,0,0">
                                <TextBlock x:Name="HotkeyLabel"
                                           Text="Ctrl+F9"
                                           Foreground="#FFFFC107"
                                           FontSize="10"
                                           FontWeight="Bold"
                                           VerticalAlignment="Center"/>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ─── LEVELS ─── -->
                <Border Grid.Column="3" Style="{StaticResource GlassCard}" Margin="5,0,0,0">
                    <StackPanel>
                        <TextBlock Text="LEVELS" Style="{StaticResource SectionTitle}"/>

                        <DockPanel Margin="0,0,0,10">
                            <TextBlock DockPanel.Dock="Left" Text="Device"
                                       Style="{StaticResource ConfigLabel}" Width="52"/>
                            <ComboBox x:Name="OutputDeviceCombo"
                                      ToolTip="Primary output device for pad playback"
                                      SelectionChanged="OutputDeviceCombo_SelectionChanged"/>
                        </DockPanel>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="52"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Output"
                                       Style="{StaticResource ConfigLabel}"/>
                            <Slider x:Name="OutputVolumeSlider"
                                    Grid.Column="1"
                                    Minimum="0" Maximum="100" Value="100"
                                    TickFrequency="5"
                                    HorizontalAlignment="Stretch"
                                    ValueChanged="OutputVolumeSlider_ValueChanged"/>
                            <Border Grid.Column="2" Style="{StaticResource ValueBadge}">
                                <TextBlock x:Name="OutputVolumeValueLabel"
                                           Text="100" FontSize="10" Width="26" TextAlignment="Center"/>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ═════════════════════ Row 2: Status + IN/OUT RMS meters ═════════════════════ -->
        <Border Grid.Row="2"
                Background="#FF0F0F1C"
                BorderBrush="#15FFFFFF"
                BorderThickness="0,0,0,1"
                Padding="14,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>   <!-- IN/OUT labels -->
                    <ColumnDefinition Width="*"/>      <!-- Meter bars -->
                    <ColumnDefinition Width="Auto"/>   <!-- dB + peak -->
                    <ColumnDefinition Width="Auto"/>   <!-- Status -->
                </Grid.ColumnDefinitions>

                <!-- IN / OUT labels -->
                <StackPanel Grid.Column="0"
                            Orientation="Vertical"
                            VerticalAlignment="Center"
                            Margin="0,0,8,0">
                    <TextBlock Text="IN"
                               Foreground="#5e31ff9e"
                               FontSize="9"
                               FontWeight="Bold"
                               HorizontalAlignment="Right"
                               Height="28"
                               Padding="0,5,0,0"/>
                    <TextBlock Text="OUT"
                               Foreground="#FF42A5F5"
                               FontSize="9"
                               FontWeight="Bold"
                               HorizontalAlignment="Right"
                               Height="28"
                               Margin="0,5,0,0"
                               Padding="0,5,0,0"/>
                </StackPanel>

                <!-- Meter bars column -->
                <StackPanel Grid.Column="1"
                            Orientation="Vertical"
                            VerticalAlignment="Center">
                    <!-- Input L channel -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="L" Grid.Column="0"
                                   Foreground="#FF7070A0" FontSize="9"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <Grid Grid.Column="1" ClipToBounds="True">
                            <Rectangle Height="14">
                                <Rectangle.Fill>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#FF2E7D32" Offset="0.0"/>
                                        <GradientStop Color="#FF4CAF50" Offset="0.35"/>
                                        <GradientStop Color="#FFFDD835" Offset="0.70"/>
                                        <GradientStop Color="#FFFF9800" Offset="0.85"/>
                                        <GradientStop Color="#FFF44336" Offset="0.95"/>
                                        <GradientStop Color="#FFD50000" Offset="1.0"/>
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                            </Rectangle>
                            <Rectangle x:Name="MeterOverlayL"
                                       Height="14"
                                       Fill="#FF0D0D18"
                                       HorizontalAlignment="Right"
                                       Width="1000"/>
                            <Canvas x:Name="ThresholdCanvas" Height="14">
                                <Rectangle x:Name="ThresholdLine"
                                           Width="2" Height="14"
                                           Fill="#FFFF9800"
                                           Canvas.Top="0"/>
                            </Canvas>
                        </Grid>
                    </Grid>
                    <!-- Input R channel -->
                    <Grid x:Name="RmsMeterRRow" Margin="0,2,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="R" Grid.Column="0"
                                   Foreground="#FF7070A0" FontSize="9"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <Grid Grid.Column="1" ClipToBounds="True">
                            <Rectangle Height="14">
                                <Rectangle.Fill>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#FF2E7D32" Offset="0.0"/>
                                        <GradientStop Color="#FF4CAF50" Offset="0.35"/>
                                        <GradientStop Color="#FFFDD835" Offset="0.70"/>
                                        <GradientStop Color="#FFFF9800" Offset="0.85"/>
                                        <GradientStop Color="#FFF44336" Offset="0.95"/>
                                        <GradientStop Color="#FFD50000" Offset="1.0"/>
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                            </Rectangle>
                            <Rectangle x:Name="MeterOverlayR"
                                       Height="14"
                                       Fill="#FF0D0D18"
                                       HorizontalAlignment="Right"
                                       Width="1000"/>
                            <Canvas x:Name="ThresholdCanvasR" Height="14">
                                <Rectangle x:Name="ThresholdLineR"
                                           Width="2" Height="14"
                                           Fill="#FFFF9800"
                                           Canvas.Top="0"/>
                            </Canvas>
                        </Grid>
                    </Grid>

                    <!-- Separator -->
                    <Rectangle Height="1" Fill="#1AFFFFFF" Margin="14,4,0,4"/>

                    <!-- Output L channel -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="L" Grid.Column="0"
                                   Foreground="#FF505070" FontSize="9"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <Grid Grid.Column="1" ClipToBounds="True">
                            <Rectangle Height="14">
                                <Rectangle.Fill>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#FF1565C0" Offset="0.0"/>
                                        <GradientStop Color="#FF42A5F5" Offset="0.35"/>
                                        <GradientStop Color="#FF80DEEA" Offset="0.70"/>
                                        <GradientStop Color="#FFFDD835" Offset="0.85"/>
                                        <GradientStop Color="#FFF44336" Offset="0.95"/>
                                        <GradientStop Color="#FFD50000" Offset="1.0"/>
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                            </Rectangle>
                            <Rectangle x:Name="OutputMeterOverlayL"
                                       Height="14"
                                       Fill="#FF0D0D18"
                                       HorizontalAlignment="Right"
                                       Width="1000"/>
                        </Grid>
                    </Grid>
                    <!-- Output R channel -->
                    <Grid Margin="0,2,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="R" Grid.Column="0"
                                   Foreground="#FF505070" FontSize="9"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <Grid Grid.Column="1" ClipToBounds="True">
                            <Rectangle Height="14">
                                <Rectangle.Fill>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#FF1565C0" Offset="0.0"/>
                                        <GradientStop Color="#FF42A5F5" Offset="0.35"/>
                                        <GradientStop Color="#FF80DEEA" Offset="0.70"/>
                                        <GradientStop Color="#FFFDD835" Offset="0.85"/>
                                        <GradientStop Color="#FFF44336" Offset="0.95"/>
                                        <GradientStop Color="#FFD50000" Offset="1.0"/>
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                            </Rectangle>
                            <Rectangle x:Name="OutputMeterOverlayR"
                                       Height="14"
                                       Fill="#FF0D0D18"
                                       HorizontalAlignment="Right"
                                       Width="1000"/>
                        </Grid>
                    </Grid>
                </StackPanel>

                <!-- dB values + peak indicators -->
                <StackPanel Grid.Column="2"
                            Orientation="Vertical"
                            VerticalAlignment="Center"
                            Margin="10,0,0,0">
                    <!-- Input dB -->
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="RmsValueLabel"
                                   Text="-∞"
                                   FontSize="10"
                                   Foreground="#FF7070A0"
                                   Width="38"/>
                        <Border x:Name="PeakIndicatorL"
                                Width="8" Height="8"
                                CornerRadius="4"
                                Background="#FF252535"
                                VerticalAlignment="Center"
                                ToolTip="Peak clip indicator"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                        <TextBlock x:Name="RmsValueLabelR"
                                   Text="-∞"
                                   FontSize="10"
                                   Foreground="#FF7070A0"
                                   Width="38"/>
                        <Border x:Name="PeakIndicatorR"
                                Width="8" Height="8"
                                CornerRadius="4"
                                Background="#FF252535"
                                VerticalAlignment="Center"
                                ToolTip="Peak clip indicator"/>
                    </StackPanel>
                    <!-- Separator spacing -->
                    <Rectangle Height="9" Fill="Transparent"/>
                    <!-- Output dB -->
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="OutputRmsValueLabel"
                                   Text="-∞"
                                   FontSize="10"
                                   Foreground="#FF404060"
                                   Width="38"/>
                        <Border x:Name="OutputPeakIndicatorL"
                                Width="8" Height="8"
                                CornerRadius="4"
                                Background="#FF252535"
                                VerticalAlignment="Center"
                                ToolTip="Output peak clip indicator"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                        <TextBlock x:Name="OutputRmsValueLabelR"
                                   Text="-∞"
                                   FontSize="10"
                                   Foreground="#FF404060"
                                   Width="38"/>
                        <Border x:Name="OutputPeakIndicatorR"
                                Width="8" Height="8"
                                CornerRadius="4"
                                Background="#FF252535"
                                VerticalAlignment="Center"
                                ToolTip="Output peak clip indicator"/>
                    </StackPanel>
                </StackPanel>

                <!-- Runtime status panel -->
                <Border Grid.Column="3"
                        Margin="18,0,0,0"
                        Padding="12,8"
                        Background="#18FFFFFF"
                        BorderBrush="#22FFFFFF"
                        BorderThickness="1"
                        CornerRadius="7"
                        MaxWidth="420">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="2" BlurRadius="10"
                                          Color="#FF000000" Opacity="0.35"/>
                    </Border.Effect>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse x:Name="StatusDot"
                                     Width="9" Height="9"
                                     Fill="#FF404055"
                                     VerticalAlignment="Center"
                                     Margin="0,0,8,0"/>
                            <TextBlock x:Name="StatusLabel"
                                       Text="Idle — press Start to begin"
                                       FontSize="11"
                                       Foreground="#FF9090B8"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       MaxWidth="360"/>
                        </StackPanel>

                        <TextBlock x:Name="InputFormatInfoLabel"
                                   Text="Input format: waiting for monitoring"
                                   Style="{StaticResource InfoLineLabel}"
                                   MaxWidth="380"/>
                        <TextBlock x:Name="OutputFormatInfoLabel"
                                   Text="Recording format: WAV | 48.0 kHz | 16-bit | stereo"
                                   Style="{StaticResource InfoLineLabel}"
                                   MaxWidth="380"/>
                        <TextBlock x:Name="StorageInfoLabel"
                                   Text="Output folder: calculating usage…"
                                   Style="{StaticResource InfoLineLabel}"
                                   MaxWidth="380"/>

                        <TextBlock x:Name="UpdateNoticeText"
                                   Visibility="Collapsed"
                                   Margin="0,3,0,0"
                                   FontSize="10"
                                   Foreground="#FFF0C04A">
                            <Hyperlink x:Name="UpdateNoticeLink"
                                       Foreground="#FFF0C04A"
                                       RequestNavigate="UpdateNoticeLink_RequestNavigate">
                                New PaDDY release available - open downloads
                            </Hyperlink>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ═════════════════════ Row 3: Favorites + Recordings pad panel ═════════════════════ -->
        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Favorites header -->
                <RowDefinition Height="Auto"/> <!-- Favorites panel -->
                <RowDefinition Height="Auto"/> <!-- Recordings header -->
                <RowDefinition Height="*"/>    <!-- Recordings scrollable area -->
            </Grid.RowDefinitions>

            <!-- ── Favorites header (hidden when empty) ── -->
            <Border x:Name="FavoritesHeader"
                    Grid.Row="0"
                    Background="#12FFC107"
                    BorderBrush="#28FFC107"
                    BorderThickness="0,0,0,1"
                    Padding="14,6"
                    Visibility="Collapsed">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="0" BlurRadius="8"
                                      Color="#FFFFC107" Opacity="0.15"/>
                </Border.Effect>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="★ FAVORITES"
                               Foreground="#FFFFC107"
                               FontSize="10"
                               FontWeight="Bold"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="FavoriteCountLabel"
                               Text=" — 0"
                               Foreground="#FF8A8A60"
                               FontSize="10"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- ── Favorites WrapPanel ── -->
            <Border x:Name="FavoritesPanelBorder"
                    Grid.Row="1"
                    Background="#0AFFC107"
                    Visibility="Collapsed"
                    Padding="12,6,12,6">
                <WrapPanel x:Name="FavoritesPanel" Orientation="Horizontal"/>
            </Border>

            <!-- ── Recordings header ── -->
            <Border Grid.Row="2"
                    Background="#FF141420"
                    BorderBrush="#18FFFFFF"
                    BorderThickness="0,0,0,1"
                    Padding="14,7">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Rectangle Width="3" Height="12" Fill="#FF4CAF50"
                                   VerticalAlignment="Center" RadiusX="1" RadiusY="1"
                                   Margin="0,0,7,0"/>
                        <TextBlock Text="RECORDINGS"
                                   Foreground="#FF5A9070"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <TextBlock x:Name="RecordingCountLabel"
                                   Text="0 clips"
                                   Foreground="#FF505070"
                                   FontSize="10"
                                   VerticalAlignment="Center"
                                   Margin="0,0,14,0"/>
                        <ComboBox x:Name="SortOrderCombo"
                                  Width="115"
                                  Height="24"
                                  Margin="0,0,8,0"
                                  ToolTip="Sort order for recordings"
                                  SelectionChanged="SortOrderCombo_SelectionChanged"/>
                        <Button Content="Clear Pads"
                                Height="24"
                                Padding="10,2"
                                Margin="0,0,6,0"
                                ToolTip="Remove pad buttons from the UI (files are kept on disk)"
                                Click="ClearPadsButton_Click"/>
                        <Button Content="&#x1F5D1; Delete All Files"
                                Height="24"
                                Padding="10,2"
                                ToolTip="Permanently delete recordings from disk"
                                Click="DeleteAllFilesButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Scrollable recordings area ── -->
            <ScrollViewer Grid.Row="3"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Background="#FF0D0D14">
                <StackPanel>
                    <WrapPanel x:Name="PadPanel"
                               Margin="12"
                               Orientation="Horizontal"/>
                    <TextBlock x:Name="EmptyHint"
                               Text="No recordings yet&#x0a;Start monitoring to capture sounds!"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="#FF303048"
                               FontSize="14"
                               TextAlignment="Center"
                               Margin="0,70,0,0"/>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
