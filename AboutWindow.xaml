<Window x:Class="PaDDY.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About PaDDY"
        Icon="PaDDY.ico"
        Width="480" Height="530"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#FF0D0D14"
        Foreground="#FFE0E8F0"
        FontFamily="{DynamicResource AppFont}">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="36"
                      GlassFrameThickness="0"
                      ResizeBorderThickness="0"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Custom title bar -->
        <Border Grid.Row="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#FF141422" Offset="0"/>
                    <GradientStop Color="#FF0F0F1A" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <TextBlock Text="About PaDDY"
                           Foreground="#FF8080A8"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Margin="16,0,0,0"/>
                <Button Style="{StaticResource ChromeCloseBtn}"
                        HorizontalAlignment="Right"
                        ToolTip="Close"
                        Click="ChromeClose_Click">
                    <TextBlock Text="&#x2715;" FontSize="11" FontFamily="Segoe UI"/>
                </Button>
            </Grid>
        </Border>

        <!-- Existing content -->
        <Grid Grid.Row="1" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0 — Logo / header -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,8,0,20">
            <StackPanel.Effect>
                <DropShadowEffect ShadowDepth="0" BlurRadius="16" Color="#FF4CAF50" Opacity="0.35"/>
            </StackPanel.Effect>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="Pa" Foreground="#FF7070A8" FontSize="30" FontWeight="Bold"/>
                <TextBlock Text="DDY" Foreground="#FF4CAF50" FontSize="30" FontWeight="Bold"/>
            </StackPanel>
            <TextBlock x:Name="VersionLabel"
                       Text="v0.0.0"
                       Foreground="#FF505080"
                       FontSize="12"
                       HorizontalAlignment="Center"
                       Margin="0,2,0,0"/>
        </StackPanel>

        <!-- Row 1 — Content card -->
        <Border Grid.Row="1"
                Style="{StaticResource GlassCard}"
                Padding="18,16">
            <StackPanel>

                <!-- Description -->
                <TextBlock TextWrapping="Wrap"
                           Foreground="#FFBBBBD8"
                           FontSize="12"
                           LineHeight="20">
                    <Run>PaDDY is a lightweight audio pad recorder that continuously listens to your microphone or system audio and lets you capture the last few seconds on demand — like a dashcam for sound.</Run>
                </TextBlock>

                <Rectangle Height="1" Fill="#14FFFFFF" Margin="0,14,0,14"/>

                <!-- Keyboard shortcuts heading -->
                <TextBlock Text="KEYBOARD SHORTCUTS"
                           Style="{StaticResource SectionTitle}"
                           Margin="0,0,0,10"/>

                <!-- Shortcut rows -->
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Save buffer to pad" Foreground="#FF9090B8" FontSize="11"/>
                    <Border Grid.Column="1" Background="#FF0C0C18" BorderBrush="#22FFFFFF" BorderThickness="1" CornerRadius="4" Padding="8,2">
                        <TextBlock Text="Ctrl + Alt + R" Foreground="#FFB0B0CC" FontSize="11" FontFamily="Consolas"/>
                    </Border>
                </Grid>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Toggle pad monitor" Foreground="#FF9090B8" FontSize="11"/>
                    <Border Grid.Column="1" Background="#FF0C0C18" BorderBrush="#22FFFFFF" BorderThickness="1" CornerRadius="4" Padding="8,2">
                        <TextBlock Text="Ctrl + Alt + M" Foreground="#FFB0B0CC" FontSize="11" FontFamily="Consolas"/>
                    </Border>
                </Grid>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Play selected pad" Foreground="#FF9090B8" FontSize="11"/>
                    <Border Grid.Column="1" Background="#FF0C0C18" BorderBrush="#22FFFFFF" BorderThickness="1" CornerRadius="4" Padding="8,2">
                        <TextBlock Text="Space" Foreground="#FFB0B0CC" FontSize="11" FontFamily="Consolas"/>
                    </Border>
                </Grid>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Delete selected pad" Foreground="#FF9090B8" FontSize="11"/>
                    <Border Grid.Column="1" Background="#FF0C0C18" BorderBrush="#22FFFFFF" BorderThickness="1" CornerRadius="4" Padding="8,2">
                        <TextBlock Text="Delete" Foreground="#FFB0B0CC" FontSize="11" FontFamily="Consolas"/>
                    </Border>
                </Grid>
                <Grid Margin="0,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Rename selected pad" Foreground="#FF9090B8" FontSize="11"/>
                    <Border Grid.Column="1" Background="#FF0C0C18" BorderBrush="#22FFFFFF" BorderThickness="1" CornerRadius="4" Padding="8,2">
                        <TextBlock Text="F2" Foreground="#FFB0B0CC" FontSize="11" FontFamily="Consolas"/>
                    </Border>
                </Grid>

                <Rectangle Height="1" Fill="#14FFFFFF" Margin="0,14,0,14"/>

                <!-- Credits link -->
                <Button x:Name="CreditsButton"
                        Content="View open-source credits..."
                        HorizontalAlignment="Left"
                        Click="CreditsButton_Click"/>

                <Rectangle Height="1" Fill="#14FFFFFF" Margin="0,14,0,14"/>

                <TextBlock x:Name="CopyrightLabel"
                           Text="© 2024"
                           Foreground="#FF383858"
                           FontSize="11"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Row 2 — Close button -->
        <Border Grid.Row="2"
                Background="#FF141420"
                BorderBrush="#14FFFFFF"
                BorderThickness="0,1,0,0"
                Padding="0,12,0,0"
                Margin="0,10,0,0">
            <Button x:Name="CloseButton"
                    Content="Close"
                    Width="100"
                    HorizontalAlignment="Right"
                    IsCancel="True"
                    Click="CloseButton_Click"/>
        </Border>
        </Grid>
    </Grid>
</Window>
