<Window x:Class="Paddy.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About Paddy"
        Icon="Paddy.ico"
        Width="420"
        Height="500"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#FF1E1E1E"
        Foreground="#FFE0E0E0"
        FontFamily="Segoe UI">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground"
                    Value="#FFD0D0D0"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background"
                    Value="#FF353535"/>
            <Setter Property="Foreground"
                    Value="#FFE0E0E0"/>
            <Setter Property="BorderBrush"
                    Value="#FF555555"/>
            <Setter Property="BorderThickness"
                    Value="1"/>
            <Setter Property="Padding"
                    Value="12,4"/>
            <Setter Property="Height"
                    Value="28"/>
            <Setter Property="Cursor"
                    Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                    VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                    Value="True">
                                <Setter TargetName="Bd"
                                        Property="Background"
                                        Value="#FF454545"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0"
                HorizontalAlignment="Center"
                Margin="0,0,0,16">
            <TextBlock Text="🎙 PaDDY"
                       FontSize="28"
                    FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Foreground="#FF4CAF50"/>
            <TextBlock x:Name="VersionLabel"
                       Text="Version 0.2.3"
                       FontSize="12"
                       HorizontalAlignment="Center"
                       Foreground="#FF9E9E9E"
                       Margin="0,4,0,0"/>
            <TextBlock Text="For Windows 10 and 11"
                       FontSize="11"
                       HorizontalAlignment="Center"
                       Foreground="#FF757575"
                       Margin="0,2,0,0"/>
        </StackPanel>

        <!-- Details -->
        <Border Grid.Row="1"
                Background="#FF252525"
                BorderBrush="#FF383838"
                BorderThickness="1"
                CornerRadius="4"
                Padding="16,12">
            <StackPanel>
                <TextBlock FontSize="11"
                        TextWrapping="Wrap"
                           Text="Paddy listens to your microphone or system audio and automatically saves clips when it detects voice activity. It also supports a Key Buffer mode for on-demand recording using a global hotkey."
                           Foreground="#FFBBBBBB"
                        Margin="0,0,0,12"/>

                <Separator Background="#FF3A3A3A"
                        Margin="0,0,0,10"/>

                <TextBlock Text="📋 License"
                        FontWeight="SemiBold"
                        Margin="0,0,0,4"/>
                <TextBlock Text="MIT License — free to use, modify, and distribute."
                           FontSize="11"
                        Foreground="#FF9E9E9E"
                        Margin="0,0,0,10"/>

                <TextBlock Text="🙏 Credits"
                        FontWeight="SemiBold"
                        Margin="0,0,0,4"/>
                <TextBlock FontSize="11"
                        Foreground="#FF9E9E9E"
                           TextWrapping="Wrap">
                    <Run Text="• NAudio (Mark Heath) — audio capture and playback"/>
                    <LineBreak/>
                    <Run Text="  Licensed under the MIT License"/>
                    <LineBreak/>
                    <Run Text="  https://github.com/naudio/NAudio"/>
                </TextBlock>

                <Separator Background="#FF3A3A3A"
                        Margin="0,10,0,10"/>

                <TextBlock x:Name="CopyrightLabel"
                           Text="© 2020-2026 NoID Softwork. All rights reserved."
                           FontSize="10"
                           Foreground="#FF616161"/>
            </StackPanel>
        </Border>

        <!-- Close button -->
        <Button Grid.Row="2"
                Content="Close"
                Width="90"
                HorizontalAlignment="Center"
                Margin="0,12,0,0"
                IsDefault="True"
                IsCancel="True"
                Click="CloseButton_Click"/>
    </Grid>
</Window>
